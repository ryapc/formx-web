---
import type { BlogPost } from '@/lib/blog';
import { formatDate, CATEGORY_LABELS } from '@/lib/blog';

interface Props {
  post: BlogPost;
  headingLevel?: 'h2' | 'h3';
}

const { post, headingLevel = 'h3' } = Astro.props;
const { title, featured_image, featured_image_alt, category, excerpt, date } = post.data;
const formattedDate = formatDate(date);
const categoryLabel = CATEGORY_LABELS[category] ?? category;
const Heading = headingLevel;
---

<div class="card blog-post">
  <a href={`/blog/${post.id}/`} class="w-inline-block">
    <div class="image-wrapper card-blog-post-featured">
      <img
        src={featured_image}
        alt={featured_image_alt || title}
        class="image card-blog-post-featured img-fluid-block"
        loading="lazy"
      />
    </div>
  </a>
  <div class="card-blog-post-featured-content">
    <a href={`/blog-post-category/${category}/`} class="badge card-blog-post">
      {categoryLabel}
    </a>
    <a href={`/blog/${post.id}/`} class="blog-post-card-link w-inline-block">
      <Heading class="h3-title-small">{title}</Heading>
    </a>
    <div class="card-blog-post-date">{formattedDate}</div>
  </div>
</div>
