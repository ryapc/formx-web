---
import type { WhatsNewEntry } from '@/lib/blog';

interface Props {
  entry: WhatsNewEntry;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { title, date, featured_image, description, tag } = entry.data;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class={`whats-new-card ${featured ? 'featured' : ''}`}>
  <a href={`/whats-new/${entry.id}/`} class="w-inline-block">
    <img src={featured_image} alt={title} loading="lazy" class="whats-new-card-image img-fluid-block" />
  </a>
  <div class="whats-new-card-content">
    <div class="new-feature-tag">{tag}</div>
    <a href={`/whats-new/${entry.id}/`} class="w-inline-block">
      <h3 class="whats-new-card-title">{title}</h3>
    </a>
    <p class="whats-new-card-description">{description}</p>
    <div class="whats-new-date">Published on {formattedDate}</div>
  </div>
</div>
