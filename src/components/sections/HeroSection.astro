---
interface CtaButton {
  text: string;
  href: string;
}

interface HeroImage {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  srcset?: string;
  sizes?: string;
}

interface Props {
  tag?: string;
  heading: string;
  subheading?: string;
  ctaPrimary?: CtaButton;
  ctaSecondary?: CtaButton;
  ctaPrimaryClass?: string;
  image?: HeroImage;
  bgClass?: string;
  showTrustIcons?: boolean;
  headingClass?: string;
  subheadingClass?: string;
}

const {
  tag,
  heading,
  subheading,
  ctaPrimary,
  ctaSecondary,
  ctaPrimaryClass = 'gray',
  image,
  bgClass = '',
  showTrustIcons = false,
  headingClass = 'product-hero-content-heading',
  subheadingClass = 'product-hero-content-subheading',
} = Astro.props;
---

<div class={`section product-hero ${bgClass}`.trim()}>
  <div class="container-default w-container min-w-0 max-w-full">
    <div class="product-hero-wrapper min-w-0">
      <div class="hero-content-block">
        <div class="product-hero-content-wrapper">
          {tag && <div class="hero-title-tag">{tag}</div>}
          <h1 class={headingClass}>{heading}</h1>
          {subheading && <div class={subheadingClass}>{subheading}</div>}
          {(ctaPrimary || ctaSecondary) && (
            <div class="w-layout-hflex action-buttons">
              {ctaPrimary && (
                <a href={ctaPrimary.href} class={`button-primary button-left ${ctaPrimaryClass} w-button`}>
                  {ctaPrimary.text}
                </a>
              )}
              {ctaSecondary && (
                <a href={ctaSecondary.href} class="button-primary button-left button-primary-shadow button-gradient w-button">
                  {ctaSecondary.text}
                </a>
              )}
            </div>
          )}
          {showTrustIcons && (
            <div class="w-layout-hflex icons">
              <div class="w-layout-hflex flex-block-27">
                <img src="/images/pages/solutions-hero-bannericon-free.svg" loading="lazy" alt="" class="img-icon" />
                <div>100 free pages</div>
              </div>
              <div class="w-layout-hflex flex-block-27">
                <img src="/images/pages/solutions-hero-bannericon-creditcard.svg" loading="lazy" alt="" class="img-icon" />
                <div>No credit card</div>
              </div>
              <div class="w-layout-hflex flex-block-27">
                <img src="/images/pages/solutions-hero-bannericon-lock.svg" loading="lazy" alt="" class="img-icon" />
                <div>100% secured</div>
              </div>
            </div>
          )}
        </div>
      </div>
      {image && (
        <div class="hero-image-block min-w-0">
          <img
            src={image.src}
            loading="lazy"
            width={image.width}
            height={image.height}
            alt={image.alt}
            srcset={image.srcset}
            sizes={image.sizes}
            class="image-7 img-fluid-block"
          />
        </div>
      )}
    </div>
  </div>
</div>
