---
// Footer navigation - 4-column grid
---

<div class="footer min-h-0 min-w-0 w-full">
  <div class="container-default w-container min-h-0 min-w-0 w-full max-w-full">
    <div class="w-layout-grid footer-grid-v2">
      <!-- Column 1: Logo, social, certs -->
      <div
        id="w-node-footer-col1"
        class="inner-container _345px mbp-full-width"
      >
        <a href="/" class="footer-logo-container logo-footer-v2 w-inline-block">
          <img
            src="/images/ui/Group-182.webp"
            width="200"
            height="40"
            alt="FormX.ai logo"
            class="footer-logo img-fluid"
          />
        </a>
        <p class="mg-bottom-24px footer-smalltext">
          FormX.ai powered by <a href="https://www.skymakers.digital" class="footer-skymakers-link"
            >SkyMakers Digital Group</a
          >
        </p>
        <div class="footer-social-media-grid left-tablet">
          <a
            href="https://www.facebook.com/formxai"
            target="_blank"
            rel="noopener"
            class="footer-social-media-link left-align-mg w-inline-block"
            aria-label="FormX on Facebook"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a
          >
          <a
            href="https://www.linkedin.com/products/oursky-limited-formxai/"
            target="_blank"
            rel="noopener"
            class="footer-social-media-link icon-small icon-footer left-align-mg w-inline-block"
            aria-label="FormX on LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg></a
          >
          <a
            href="https://www.youtube.com/watch?v=9vmAz4wE-Eg"
            target="_blank"
            rel="noopener"
            class="footer-social-media-link icon-small icon-footer left-align-mg w-inline-block"
            aria-label="FormX on YouTube"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg></a
          >
        </div>
        <div class="footer-certificate">
          <img
            src="/images/ui/FormX_footer_certificated_blue@2x.png"
            loading="lazy"
            width="145"
            height="73"
            alt="ISO 27001 and SOC 2 Type II certified"
            class="certificate-img img-fluid"
          />
          <div class="certificate-text">FormX.ai is both ISO 27001 and SoC 2 Type II compliant.</div>
        </div>
      </div>

      <!-- Column 2: Converting Tools -->
      <div id="w-node-footer-col2" class="footer-menu-links-wrapper">
        <div class="title footer-menu">Converting Tools</div>
        <ul role="list" class="footer-menu-list mg-right-responsive w-list-unstyled">
          <li class="footer-menu-list-item">
            <a href="/tools/invoice-ocr-api/" class="footer-menu-link w-inline-block"
              ><div>Invoice</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/tools/bank-statement-converter/" class="footer-menu-link w-inline-block"
              ><div>Bank Statement</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/tools/image-to-excel-converter/" class="footer-menu-link w-inline-block"
              ><div>Image to Excel</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/tools/pdf-to-csv-converter/" class="footer-menu-link w-inline-block"
              ><div class="footer-menu-link">PDF to CSV</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/tools/pdf-to-xml-converter/" class="footer-menu-link w-inline-block"
              ><div>PDF to XML</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/tools/pdf-to-json-converter/" class="footer-menu-link w-inline-block"
              ><div>PDF to JSON</div></a
            >
          </li>
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div class="footer-menu-links-wrapper">
        <div class="title footer-menu">Resources</div>
        <ul role="list" class="footer-menu-list w-list-unstyled">
          <li class="footer-menu-list-item">
            <a href="https://help.formx.ai/" class="footer-menu-link w-inline-block"
              ><div>Documentation</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="https://help.formx.ai/discuss" class="footer-menu-link w-inline-block"
              ><div>Community</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="https://help.formx.ai/reference" class="footer-menu-link w-inline-block"
              ><div>APIs</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="https://status.formx.ai/" class="footer-menu-link w-inline-block"
              ><div>Status</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/success-stories/" class="footer-menu-link w-inline-block"
              ><div>Success Stories</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/service-level-agreement/" class="footer-menu-link w-inline-block"
              ><div>SLA</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/terms-of-service/" class="footer-menu-link w-inline-block"
              ><div>Terms of Services</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="/data-privacy-policy/" class="footer-menu-link w-inline-block"
              ><div>Privacy Policy</div></a
            >
          </li>
          <li class="footer-menu-list-item">
            <a href="#" data-cc="show-preferencesModal" class="footer-menu-link w-inline-block"
              ><div>Cookie Settings</div></a
            >
          </li>
        </ul>
      </div>

      <!-- Column 4: Company -->
      <div class="footer-menu-links-wrapper last">
        <div class="title footer-menu">Company</div>
        <ul role="list" class="footer-menu-list w-list-unstyled">
          <li class="footer-menu-list-item">
            <a href="https://www.skymakers.digital" class="footer-menu-link w-inline-block"
              ><div>Skymakers Digital</div></a
            >
          </li>

        </ul>
      </div>
    </div>
  </div>
</div>
