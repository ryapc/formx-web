---
import { SIGNUP_URL, DEMO_CALENDLY_URL } from '@/lib/constants';
import Footer from '@/components/footer/Footer.astro';

interface Props {
  heading?: string;
  subtitle?: string | null;
  description?: string;
  ctaHref?: string | null;
  ctaText?: string;
}

const {
  heading,
  subtitle,
  description,
  ctaHref,
  ctaText,
} = Astro.props;

const defaultHeading = `Ready to<span class="text-color-primary">Automate</span> Your Document Processing?`;
const resolvedHeading = heading ?? defaultHeading;
const resolvedSubtitle = subtitle !== undefined ? subtitle : 'Free trials available.';
const resolvedDescription = description ?? 'Schedule a Demo meeting with us and see your documents processed in real-time!';
const resolvedCtaHref = ctaHref !== undefined ? ctaHref : SIGNUP_URL;
const resolvedCtaText = ctaText ?? 'Start for Free ->';
---

<section class="bg-f7f8fc">
<div
  class="footer-with-form -mt-[60px] max-[767px]:-mt-10 bg-transparent"
>
  <div class="section footer-form">
    <div class="w-layout-blockcontainer container-default w-container min-w-0 max-w-full">
      <div class="_2-block-flex footer-form">
        <div class="footer-left min-w-0 max-w-full lg:basis-1/2 lg:shrink-0">
          {resolvedSubtitle && <div class="footer-subtitle-2">{resolvedSubtitle}</div>}
          <h2 class="footer-heading" set:html={resolvedHeading} />
          <div class="footer-paragraph" set:text={resolvedDescription} />
          {resolvedCtaHref && <a href={resolvedCtaHref} class="button-primary button-left button-gradient mobile-full w-button"
            >{resolvedCtaText}</a
          >}
        </div>
        <div class="footer-right min-w-0 w-full max-w-full lg:basis-1/2">
          <div class="footer-form-wrap">
            <div class="w-form">
              <form
                id="wf-form-Email-Form"
                name="schedule-demo"
                netlify
                netlify-honeypot="bot-field"
                data-redirect={DEMO_CALENDLY_URL}
                method="post"
                class="form-3"
              >
                <input type="hidden" name="form-name" value="schedule-demo" />
                <p style="display:none"><label>Don't fill this out: <input name="bot-field" type="text" /></label></p>
                <div class="w-layout-blockcontainer container-1470 w-container">
                  <label for="Name-2" class="form-label"
                    >Full Name<span class="get-demo-form-label-required">*</span></label
                  >
                  <input
                    class="form-text-field w-input"
                    maxlength="256"
                    name="Name"
                    data-name="Name"
                    placeholder=""
                    type="text"
                    id="Name-2"
                    autocomplete="name"
                    required
                  />
                </div>
                <div class="w-layout-blockcontainer container-1472 w-container">
                  <label for="Email-2" class="form-label"
                    >Work Email<span class="get-demo-form-label-required">*</span></label
                  >
                  <input
                    class="form-text-field w-input"
                    maxlength="256"
                    name="Email"
                    data-name="Email"
                    placeholder=""
                    type="email"
                    id="Email-2"
                    autocomplete="email"
                    required
                  />
                </div>
                <div class="w-layout-blockcontainer container-1473 w-container">
                  <label for="pages" class="form-label"
                    >How many documents you need to automate per month?<span
                      class="get-demo-form-label-required">*</span
                    ></label
                  >
                  <input
                    class="form-text-field w-input"
                    maxlength="256"
                    name="pages"
                    data-name="pages"
                    placeholder=""
                    type="text"
                    id="pages"
                    required
                  />
                </div>
                <div class="w-layout-blockcontainer container-1474 w-container">
                  <label for="field" class="form-label">Other</label>
                  <textarea
                    placeholder="Please share anything that will help prepare for our meeting. E.g. document type, workflow etc"
                    maxlength="5000"
                    id="field"
                    name="field"
                    data-name="Field"
                    class="form-input form-text-field w-input"></textarea>
                </div>
                <input
                  type="submit"
                  data-wait="Please wait..."
                  class="footer-form-submit w-button"
                  value="Submit"
                />
              </form>
              <div class="w-form-done">
                <div class="text-block-51">
                  Thank you. Your submission has been received.<br /><br />Check your email for next
                  steps.
                </div>
              </div>
              <div class="w-form-fail">
                <div>
                  Oops! Something went wrong while submitting the form. Please email us directly at
                  hello@formx.ai.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Footer />
</div>
</section>

<script is:inline>
  (function() {
    var formEl = document.querySelector('#wf-form-Email-Form');
    if (!formEl) return;
    formEl.addEventListener('submit', function(e) {
      e.preventDefault();
      var wform = formEl.closest('.w-form');
      var done = wform && wform.querySelector('.w-form-done');
      var fail = wform && wform.querySelector('.w-form-fail');
      var redirectUrl = formEl.getAttribute('data-redirect');
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(formEl)).toString()
      })
        .then(function() {
          formEl.style.display = 'none';
          if (done) done.style.display = 'block';
          if (redirectUrl) setTimeout(function() { window.location.href = redirectUrl; }, 1500);
        })
        .catch(function() {
          if (fail) fail.style.display = 'block';
        });
    });
  })();
</script>
