---
import SEO from '@/components/head/SEO.astro';
import Analytics from '@/components/head/Analytics.astro';
import CookieConsent from '@/components/head/CookieConsent.astro';
import FontLoader from '@/components/head/FontLoader.astro';
import '@/styles/main.css';
import '@/styles/tailwind.css';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterCard?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  twitterCard,
  canonicalUrl,
  noIndex,
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />

    <SEO
      {title}
      {description}
      {ogTitle}
      {ogDescription}
      {ogImage}
      {twitterCard}
      {canonicalUrl}
      {noIndex}
    />

    <!-- Favicons -->
    <link
      href="/images/ui/Favicon_32x32.png"
      rel="shortcut icon"
      type="image/x-icon"
    />
    <link
      href="/images/ui/Favicon_256x256.png"
      rel="apple-touch-icon"
    />

    <FontLoader />
    <Analytics />
    <CookieConsent />

    <!-- Per-page extra head content (JSON-LD, page-specific styles) -->
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-to-main">Skip to main content</a>
    <slot />

    <!-- Vanilla tab switching for w-tabs components -->
    <script is:inline>
      function setTabDescHeight(link, isActive, animate) {
        var desc = link.querySelector('.hover-change-description, .hover-change-description-2');
        if (!desc) return;
        if (!animate) desc.style.transition = 'none';
        desc.style.height = isActive ? desc.scrollHeight + 'px' : '0px';
        if (!animate) {
          requestAnimationFrame(function() {
            requestAnimationFrame(function() { desc.style.transition = ''; });
          });
        }
      }

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.w-tab-menu').forEach(function(menu) {
          menu.querySelectorAll('.w-tab-link').forEach(function(link) {
            setTabDescHeight(link, link.classList.contains('w--current'), false);
          });
        });
      });

      document.addEventListener('click', function(e) {
        var link = e.target.closest('.w-tab-link');
        if (!link) return;
        e.preventDefault();
        var menu = link.closest('.w-tab-menu');
        var tabs = menu && menu.closest('.w-tabs');
        var content = tabs && tabs.querySelector('.w-tab-content');
        if (!menu || !content) return;
        var links = Array.from(menu.querySelectorAll('.w-tab-link'));
        var idx = links.indexOf(link);
        links.forEach(function(l, i) {
          l.classList.toggle('w--current', i === idx);
          setTabDescHeight(l, i === idx, true);
        });
        Array.from(content.querySelectorAll('.w-tab-pane')).forEach(function(p, i) {
          p.classList.toggle('w--tab-active', i === idx);
        });
      });
    </script>

    <!-- Legacy w-accordion (faq2_question pattern) fallback -->
    <script is:inline>
      document.querySelectorAll('.faq2_question[data-w-id]').forEach(function(q) {
        q.addEventListener('click', function() {
          var answer = q.nextElementSibling;
          if (!answer) return;
          var isOpen = answer.style.height !== '0px' && answer.style.height !== '';
          answer.style.overflow = 'hidden';
          answer.style.height = isOpen ? '0px' : answer.scrollHeight + 'px';
        });
      });
    </script>

    <!-- LinkedIn Insight Tag - gated by cookie consent (marketing category) -->
    <script is:inline type="text/plain" data-category="marketing">
      _linkedin_partner_id = "4504041";
      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      window._linkedin_data_partner_ids.push(_linkedin_partner_id);
    </script>
    <script is:inline type="text/plain" data-category="marketing">
      (function (l) {
        if (!l) {
          window.lintrk = function (a, b) {
            window.lintrk.q.push([a, b]);
          };
          window.lintrk.q = [];
        }
        var s = document.getElementsByTagName('script')[0];
        var b = document.createElement('script');
        b.type = 'text/javascript';
        b.async = true;
        b.src = 'https://snap.licdn.com/li.lms-analytics/insight.min.js';
        s.parentNode.insertBefore(b, s);
      })(window.lintrk);
    </script>

    <!-- Apollo Website Tracker - gated by cookie consent (marketing category) -->
    <script is:inline type="text/plain" data-category="marketing">
      (function () {
        var n = Math.random().toString(36).substring(7),
          o = document.createElement('script');
        o.src =
          'https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache=' + n;
        o.async = true;
        o.defer = true;
        o.onload = function () {
          window.trackingFunctions.onLoad({ appId: '6632e61c4846e902e874652d' });
        };
        document.head.appendChild(o);
      })();
    </script>

  </body>
</html>
