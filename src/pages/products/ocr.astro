---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
---

<PageLayout
  title="OCR Technology Powered by Google &amp; Microsoft"
  description=""
  canonicalUrl="https://www.formx.ai/products/ocr"
  showFooterForm={true}
>
  <HeroSection
    tag="OCR"
    heading="What is Optical Character Recognition (OCR)"
    subheading="Optical character recognition (OCR) is a technology designed to extract text from images, covering the scanning of GIF, JPG, PNG, and TIFF image formats."
    ctaPrimary={{ text: "Talk to Us ->", href: "/schedule-demo" }}
    ctaPrimaryClass="button-white"
    bgClass="bg-green-shapes-v2"
    headingClass="product-hero-content-heading color-white"
    subheadingClass="product-hero-content-subheading color-white"
    image={{
      src: "/images/pages/products_ocr-kv@2x.webp",
      alt: "",
      width: 2400,
      height: 1800,
      srcset: "/images/pages/products_ocr-kv@2x-p-500.webp 500w, /images/pages/products_ocr-kv@2x-p-800.webp 800w, /images/pages/products_ocr-kv@2x-p-1080.webp 1080w, /images/pages/products_ocr-kv@2x-p-1600.webp 1600w, /images/pages/products_ocr-kv@2x-p-2000.webp 2000w, /images/pages/products_ocr-kv@2x.webp 2400w",
      sizes: "(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px",
    }}
  />

  <div class="section product-section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Modern OCR&nbsp;Engine</h2>
          <div class="product-subheading">The OCR technology recognizes characters from images and transforms them into unstructured text. With FormX.ai, the accuracy of outcomes can be further improved.</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="statistic-card-wrapper bg-0fac900d">
              <div class="statistic-card-inner">
                <div class="statistic-card-top">
                  <div class="statistic-card-top-title text-color-primary">Google OCR</div>
                </div>
              </div>
            </div>
            <div class="statistic-card-wrapper bg-0fac900d">
              <div class="statistic-card-inner">
                <div class="statistic-card-top">
                  <div class="statistic-card-top-title text-color-primary">Azure OCR</div>
                </div>
              </div>
            </div>
            <div class="statistic-card-wrapper bg-0fac900d">
              <div class="statistic-card-inner">
                <div class="statistic-card-top">
                  <div class="statistic-card-top-title text-color-primary">Tesseract OCR</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section">
    <div class="container-default w-container">
      <div class="card-xl bg-f3fbf9">
        <div class="card-xl-2-block-wrapper">
          <div class="card-xl-content-wrap">
            <h2 class="card-xl-title text-color-primary">An Example of OCR</h2>
            <div class="card-xl-description text-838c9b">Scan an image and obtain the characters as unstructured text.</div>
          </div>
          <div class="card-xl-image-wrap">
            <img
              src="/images/pages/products_ocr-example-ocr@2x.webp"
              loading="lazy"
              width="2400"
              height="1800"
              sizes="(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px"
              alt=""
              srcset="/images/pages/products_ocr-example-ocr@2x-p-500.webp 500w, /images/pages/products_ocr-example-ocr@2x-p-800.webp 800w, /images/pages/products_ocr-example-ocr@2x-p-1080.webp 1080w, /images/pages/products_ocr-example-ocr@2x-p-1600.webp 1600w, /images/pages/products_ocr-example-ocr@2x-p-2000.webp 2000w, /images/pages/products_ocr-example-ocr@2x.webp 2400w"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-10">
    <div class="container-default-7 heading-content flex w-container">
      <div class="product-heading-wrapper mb-60">
        <h2 class="product-heading">Go Beyond OCR - Unlock Powerful Document Understanding with AI</h2>
        <div class="product-subheading">While OCR (Optical Character Recognition) is a valuable tool, FormX.ai offers a more intelligent approach. We leverage the power of AI to extract data with unmatched accuracy and understanding, going far beyond simple text recognition.</div>
      </div>
      <div data-current="Tab 1" data-easing="ease" data-duration-in="300" data-duration-out="100" class="_2-block-flex tabs-with-image w-tabs">
        <div class="hover-change tabs w-tab-menu">
          <a data-w-tab="Tab 1" data-w-id="2759ee11-d371-e228-b210-77ce12a62c7c" class="hover-change-content-2 w-inline-block w-tab-link w--current">
            <div class="hover-change-title">Pre-processing</div>
            <div style="height:0px" class="hover-change-description-2">Get the document ready for reading (fixing scans, aligning text).</div>
          </a>
          <a data-w-tab="Tab 2" data-w-id="2759ee11-d371-e228-b210-77ce12a62c81" class="hover-change-content-2 w-inline-block w-tab-link">
            <div class="hover-change-title">OCR</div>
            <div style="height:0px" class="hover-change-description-2">Convert the image into editable text.</div>
          </a>
          <a data-w-tab="Tab 3" data-w-id="2759ee11-d371-e228-b210-77ce12a62c86" class="hover-change-content-2 w-inline-block w-tab-link">
            <div class="hover-change-title">Extract &amp;&nbsp;layout</div>
            <div style="height:0px" class="hover-change-description-2">Identify and categorize important information (with AI!)</div>
          </a>
          <a data-w-tab="Tab 4" data-w-id="59876cf4-cbaf-779c-8750-470da1181e5d" class="hover-change-content-2 w-inline-block w-tab-link">
            <div class="hover-change-title">Return a JSON</div>
            <div style="height:0px" class="hover-change-description-2">Package the data in a clean format for easy use.</div>
          </a>
        </div>
        <div class="_2-block-flex-image tabs w-tab-content">
          <div data-w-tab="Tab 1" class="w-tab-pane w--tab-active">
            <img width="600" sizes="(max-width: 767px) 100vw, 600px" alt="" src="/images/pages/products_ocr-data-extraction-01.png" loading="eager" srcset="/images/pages/products_ocr-data-extraction-01-p-500.png 500w, /images/pages/products_ocr-data-extraction-01-p-800.png 800w, /images/pages/products_ocr-data-extraction-01-p-1080.png 1080w, /images/pages/products_ocr-data-extraction-01.png 1200w" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 2" class="w-tab-pane">
            <img width="600" loading="eager" alt="" src="/images/pages/products_ocr-data-extraction-02.png" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 3" class="w-tab-pane">
            <img width="600" loading="eager" alt="" src="/images/pages/products_ocr-data-extraction-03.png" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 4" class="w-tab-pane">
            <img width="600" loading="eager" alt="" src="/images/pages/products_ocr-data-extraction-04.png" class="_2-block-image-radius" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-80">
          <h2 class="product-heading">Don't Just Read It, Understand It: <br />The Power of FormX.ai</h2>
          <div class="product-subheading">Basic OCR tools are like a basic translator - they convert words from one language to another, but don't grasp the meaning. FormX.ai goes far beyond, using Machine Learning to unlock the true potential of your documents:</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card card-bg-white card-small">
              <div class="card-svg-block">
                <img src="/images/pages/structured-data-extraction.svg" loading="lazy" width="48" id="sma" alt="" class="card-svg xs" />
              </div>
              <div class="svg-card-content-wrapper plain-svg-card-align-left">
                <div class="svg-card-title bold-text plain-svg-card-align-left">Structured Data Extraction</div>
                <div class="svg-card-description">Transform raw text into categorized information, like identifying the total amount on a receipt.</div>
              </div>
            </div>
            <div id="w-node-_7edbdbc4-f004-8dcb-29c7-d0ac7d24a34b-c3c5a903" class="plain-svg-card card-bg-white card-small">
              <div class="card-svg-block">
                <img src="/images/pages/intelligent-processing.svg" loading="lazy" width="48" alt="" class="card-svg xs" />
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Intelligent Processing</div>
                <div class="svg-card-description">Understands context, not just characters, allowing for accurate data capture.</div>
              </div>
            </div>
            <div id="w-node-_7edbdbc4-f004-8dcb-29c7-d0ac7d24a353-c3c5a903" class="plain-svg-card card-bg-white card-small">
              <div class="card-svg-block">
                <img src="/images/pages/effortless-workflow-integration.svg" loading="lazy" width="48" alt="" class="card-svg xs" />
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text plain-svg-card-align-left">Effortless Workflow Integration</div>
                <div class="svg-card-description">Extracted data is delivered in a clean format (like JSON) for seamless use with other applications.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
