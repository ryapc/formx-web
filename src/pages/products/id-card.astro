---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
---

<PageLayout
  title="Secure Your Digital Onboarding with FormX.ai's Advanced ID Liveness Detection"
  description=""
  canonicalUrl="https://www.formx.ai/products/id-card"
>
  <HeroSection
    heading="Secure Your Digital Onboarding with FormX.ai's ID Liveness Detection"
    subheading="FormX.ai's ID liveness detection ensures only real users access your platform. Say goodbye to fake IDs and hello to secure digital onboarding."
    ctaPrimary={{ text: "Talk to Us ->", href: "/schedule-demo" }}
    ctaPrimaryClass="button-white"
    bgClass="bg-green-shapes-v2"
    headingClass="product-hero-content-heading color-white"
    subheadingClass="product-hero-content-subheading color-white"
    image={{
      src: "/images/pages/products_idp-kv.webp",
      alt: "",
      width: 2400,
      height: 1800,
      srcset: "/images/pages/products_idp-kv-p-500.webp 500w, /images/pages/products_idp-kv-p-800.webp 800w, /images/pages/products_idp-kv-p-1080.webp 1080w, /images/pages/products_idp-kv-p-1600.webp 1600w, /images/pages/products_idp-kv-p-2000.webp 2000w, /images/pages/products_idp-kv.webp 2400w",
      sizes: "(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px",
    }}
  />

  <div class="section">
    <div class="container-default heading-content flex w-container">
      <div class="home-heading left mw-50 mb-1">
        <h2>FormX Workspace:&#x2028;<br />Manage Your Extractions Seamlessly</h2>
        <div class="product-subheading mw-625">FormX Workspace empowers you to streamline your data extraction process within a centralized platform. Here's how:</div>
      </div>
      <div data-current="Tab 2" data-easing="ease" data-duration-in="300" data-duration-out="100" class="_2-block-flex tabs-with-image w-tabs">
        <div class="hover-change accordion w-tab-menu">
          <a data-w-tab="Tab 2" data-w-id="8e377e81-36c4-67cf-7a94-4b773a979568" class="hover-change hover-change-content accordion w-inline-block w-tab-link w--current">
            <div class="hover-change_accordion_title-wrap">
              <div class="hover-change_accordion_title-wrap_img">
                <img loading="lazy" src="/images/pages/Copy-2.svg" alt="" />
                <div class="hover-change-title">Color Copies</div>
                <img loading="lazy" src="/images/pages/faq_arrow.svg" alt="" class="hover-change_accordion_arrow" />
              </div>
            </div>
            <div class="hover-change-description accordion">Scanned images, or even color printouts of real IDs, won't fool our system.</div>
          </a>
          <a data-w-tab="Tab 6" data-w-id="3e5cd6d8-04ac-1508-b3df-586064c22e7e" class="hover-change hover-change-content accordion w-inline-block w-tab-link">
            <div class="hover-change_accordion_title-wrap">
              <div class="hover-change_accordion_title-wrap_img">
                <img loading="lazy" src="/images/pages/Copy-2.svg" alt="" />
                <div class="hover-change-title">Greyscale Copies</div>
                <img loading="lazy" src="/images/pages/faq_arrow.svg" alt="" class="hover-change_accordion_arrow" />
              </div>
            </div>
            <div class="hover-change-description accordion">Scanned images, or even color printouts of real IDs, won't fool our system.</div>
          </a>
          <a data-w-tab="Tab 7" data-w-id="53e22fa7-ca10-0557-c3fd-c86df2add57a" class="hover-change hover-change-content accordion w-inline-block w-tab-link">
            <div class="hover-change_accordion_title-wrap">
              <div class="hover-change_accordion_title-wrap_img">
                <img loading="lazy" src="/images/pages/Copy-2.svg" alt="" />
                <div class="hover-change-title">Screen Replays</div>
                <img loading="lazy" src="/images/pages/faq_arrow.svg" alt="" class="hover-change_accordion_arrow" />
              </div>
            </div>
            <div class="hover-change-description accordion">Scanned images, or even color printouts of real IDs, won't fool our system.</div>
          </a>
        </div>
        <div class="_2-block-flex-image tabs overflow-visible transform w-tab-content">
          <div data-w-tab="Tab 2" class="w-tab-pane w--tab-active">
            <img width="600" sizes="100vw" alt="" src="/images/pages/products_idcard_security-01@2x.webp" loading="eager" srcset="/images/pages/products_idcard_security-01@2x-p-500.webp 500w, /images/pages/products_idcard_security-01@2x-p-800.webp 800w, /images/pages/products_idcard_security-01@2x-p-1080.webp 1080w, /images/pages/products_idcard_security-01@2x.webp 1200w" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 6" class="w-tab-pane">
            <img width="600" sizes="100vw" alt="" src="/images/pages/products_idcard_security-02@2x.webp" loading="eager" srcset="/images/pages/products_idcard_security-02@2x-p-500.webp 500w, /images/pages/products_idcard_security-02@2x-p-800.webp 800w, /images/pages/products_idcard_security-02@2x-p-1080.webp 1080w, /images/pages/products_idcard_security-02@2x.webp 1200w" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 7" class="w-tab-pane">
            <img width="600" sizes="100vw" alt="" src="/images/pages/products_idcard_security-03@2x.webp" loading="eager" srcset="/images/pages/products_idcard_security-03@2x-p-500.webp 500w, /images/pages/products_idcard_security-03@2x-p-800.webp 800w, /images/pages/products_idcard_security-03@2x-p-1080.webp 1080w, /images/pages/products_idcard_security-03@2x.webp 1200w" class="_2-block-image-radius" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Unveiling the Power of FormX.ai Mobile SDK Features</h2>
          <div class="product-subheading">The FormX.ai Mobile SDK offers a robust set of functionalities designed to elevate your mobile app's document capture capabilities. This table provides a detailed breakdown of each feature and its purpose:</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card card-bg-white card-content-center p-0">
              <div class="card-svg-block">
                <img src="/images/pages/products_idcard_features-01@2x.webp" loading="lazy" width="80" sizes="(max-width: 1279px) 80px, (max-width: 1439px) 6vw, 80px" alt="" srcset="/images/pages/products_idcard_features-01@2x-p-500.webp 500w, /images/pages/products_idcard_features-01@2x-p-800.webp 800w, /images/pages/products_idcard_features-01@2x.webp 811w" class="card-svg full-width image-rounded" />
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Capture Your ID</div>
                <div class="svg-card-description">Simply take a photo of your government-issued ID using your mobile device.</div>
              </div>
            </div>
            <div id="w-node-_80081a4e-f388-4c4b-3ea9-43ecd3f91eab-6487340d" class="plain-svg-card card-bg-white card-content-center p-0">
              <div class="card-svg-block">
                <img src="/images/pages/products_idcard_features-02@2x.webp" loading="lazy" width="80" sizes="(max-width: 1279px) 80px, (max-width: 1439px) 6vw, 80px" alt="" srcset="/images/pages/products_idcard_features-02@2x-p-500.webp 500w, /images/pages/products_idcard_features-02@2x-p-800.webp 800w, /images/pages/products_idcard_features-02@2x.webp 811w" class="card-svg full-width image-rounded" />
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Snap a Selfie</div>
                <div class="svg-card-description">Use your front camera to take a quick selfie.</div>
              </div>
            </div>
            <div id="w-node-_80081a4e-f388-4c4b-3ea9-43ecd3f91eb3-6487340d" class="plain-svg-card card-bg-white card-content-center p-0">
              <div class="card-svg-block">
                <img src="/images/pages/products_idcard_features-03@2x.webp" loading="lazy" width="80" sizes="(max-width: 1279px) 80px, (max-width: 1439px) 6vw, 80px" alt="" srcset="/images/pages/products_idcard_features-03@2x-p-500.webp 500w, /images/pages/products_idcard_features-03@2x-p-800.webp 800w, /images/pages/products_idcard_features-03@2x.webp 811w" class="card-svg full-width image-rounded" />
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Instant Verification</div>
                <div class="svg-card-description">FormX.ai's advanced technology compares your selfie to the portrait on your ID, ensuring a perfect match.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="section mobile-sdk">
    <div class="w-layout-blockcontainer container-default w-container">
      <div class="_2-block-flex mobile-footer">
        <div class="div-block-3">
          <img src="/images/pages/products_try_app@2x.webp" loading="lazy" width="1433" height="1654" sizes="(max-width: 767px) 100vw, 716.5px" alt="" srcset="/images/pages/products_try_app@2x-p-500.webp 500w, /images/pages/products_try_app@2x-p-800.webp 800w, /images/pages/products_try_app@2x-p-1080.webp 1080w, /images/pages/products_try_app@2x.webp 1433w" class="mobile-footer_left-image" />
        </div>
        <div class="mobile-footer_right">
          <div class="mobile-footer_right-image">
            <div class="mobile-footer_right_top-image-wrap">
              <img src="/images/pages/products_try_app-icon@2x.webp" loading="lazy" width="80" alt="" />
            </div>
          </div>
          <div class="mobile-footer_right_links">
            <h2 class="mobile-footer_right_content-title">Experience the Power Firsthand: Try our Mobile SDK Demo App!</h2>
            <div class="mobile-footer_right_content-description">We've created intuitive demo apps for both iOS and Android platforms that showcase the functionalities of the FormX.ai Mobile SDK in action.</div>
          </div>
          <div class="mobile-footer_right_links">
            <div class="mobile-footer_right_content-description paragraph-small">Download the app and experiment with features like real-time document detection, image quality analysis, and more!</div>
            <div class="mobile-footer_right_links-inner">
              <div>
                <a href="https://apps.apple.com/us/app/ai-scan-formx/id6444301909" class="w-inline-block">
                  <img src="/images/pages/products_try_app-iOS.svg" loading="lazy" alt="" />
                </a>
              </div>
              <div>
                <a href="https://play.google.com/store/apps/details?id=com.formextractorai.demo.android" class="w-inline-block">
                  <img src="/images/pages/products_try_app-GooglePlay.svg" loading="lazy" alt="" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="footer-translate"></div>
</PageLayout>
