---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
---

<PageLayout
  title="FormX Workspace: Revolutionize Your Document Workflow (Free Trial)"
  description=""
  canonicalUrl="https://www.formx.ai/products/document-workspace"
  showFooterForm={true}
>
  <HeroSection
    tag="Document Workspace"
    heading="FormX.ai Workspace: Unleash the Power of Organized Extraction"
    subheading="FormX Workspace transforms your data extraction process. Upload documents, manage results, collaborate with ease, and connect with your favorite tools – all within a centralized platform."
    ctaPrimary={{ text: "Talk to Us ->", href: "/schedule-demo" }}
    ctaPrimaryClass="button-white"
    bgClass="bg-green-shapes-v2"
    headingClass="product-hero-content-heading color-white"
    subheadingClass="product-hero-content-subheading color-white"
    image={{
      src: "/images/pages/products_idp-kv.webp",
      alt: "",
      width: 2400,
      height: 1800,
      srcset: "/images/pages/products_idp-kv-p-500.webp 500w, /images/pages/products_idp-kv-p-800.webp 800w, /images/pages/products_idp-kv-p-1080.webp 1080w, /images/pages/products_idp-kv-p-1600.webp 1600w, /images/pages/products_idp-kv-p-2000.webp 2000w, /images/pages/products_idp-kv.webp 2400w",
      sizes: "(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px",
    }}
  />

  <div class="section">
    <div class="container-default heading-content flex w-container">
      <div class="home-heading content-center">
        <h2 class="text-center">FormX Workspace:&#x2028;<br />Manage Your Extractions Seamlessly</h2>
        <div class="product-subheading mw-625 text-center">FormX Workspace empowers you to streamline your data extraction process within a centralized platform. Here's how:</div>
      </div>
      <div data-current="Tab 1" data-easing="ease" data-duration-in="300" data-duration-out="100" class="_2-block-flex tabs-with-image w-tabs">
        <div class="hover-change tabs w-tab-menu">
          <a data-w-tab="Tab 1" data-w-id="8e377e81-36c4-67cf-7a94-4b773a979563" class="hover-change-content w-inline-block w-tab-link w--current">
            <div class="hover-change-title">Effortless Document Management</div>
            <div style="height:0px" class="hover-change-description">Upload various documents (PDFs, JPGs, PNGs, and WebP) for batch processing. Drag and drop functionality makes it simple to add multiple files at once.</div>
          </a>
          <a data-w-tab="Tab 2" data-w-id="8e377e81-36c4-67cf-7a94-4b773a979568" class="hover-change-content w-inline-block w-tab-link">
            <div class="hover-change-title">Extraction Results at Your Fingertips</div>
            <div style="height:0px" class="hover-change-description">View and manage the extracted data from your uploaded documents directly within the Workspace.</div>
          </a>
          <a data-w-tab="Tab 3" data-w-id="01b47e93-7bad-b349-ae15-d3e2a22020d3" class="hover-change-content w-inline-block w-tab-link">
            <div class="hover-change-title">Excel Download for Further Analysis</div>
            <div style="height:0px" class="hover-change-description">Easily download the extracted data as Excel files for seamless integration with your existing spreadsheets and data analysis tools.</div>
          </a>
          <a data-w-tab="Tab 4" data-w-id="adcee2b4-0cfe-0ff0-48b6-c3b70b34b514" class="hover-change-content w-inline-block w-tab-link">
            <div class="hover-change-title">Enhanced Collaboration</div>
            <div style="height:0px" class="hover-change-description">Collaborate with colleagues by sharing your Workspace, allowing everyone to stay on the same page regarding data extraction tasks.</div>
          </a>
          <a data-w-tab="Tab 5" data-w-id="c082bd27-3928-b4d7-50a6-de9ab3707192" class="hover-change-content w-inline-block w-tab-link">
            <div class="hover-change-title">Third-Party Integration</div>
            <div style="height:0px" class="hover-change-description">Connect FormX Workspace with your preferred third-party platforms or applications to automate your workflows and maximize efficiency.</div>
          </a>
        </div>
        <div class="_2-block-flex-image tabs w-tab-content">
          <div data-w-tab="Tab 1" class="w-tab-pane w--tab-active">
            <img loading="eager" src="/images/pages/product_document_workspace-manage-effortless.svg" alt="" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 2" class="w-tab-pane">
            <img width="600" loading="eager" alt="" src="/images/pages/product_document_workspace-manage-extraction.svg" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 3" class="w-tab-pane">
            <img width="600" sizes="100vw" alt="" src="/images/pages/product_document_workspace-manage-exceldownload@2x.webp" loading="eager" srcset="/images/pages/product_document_workspace-manage-exceldownload@2x-p-500.webp 500w, /images/pages/product_document_workspace-manage-exceldownload@2x-p-800.webp 800w, /images/pages/product_document_workspace-manage-exceldownload@2x-p-1080.webp 1080w, /images/pages/product_document_workspace-manage-exceldownload@2x.webp 1200w" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 4" class="w-tab-pane">
            <img width="600" sizes="100vw" alt="" src="/images/pages/product_document_workspace-manage-collaboration@2x.webp" loading="eager" srcset="/images/pages/product_document_workspace-manage-collaboration@2x-p-500.webp 500w, /images/pages/product_document_workspace-manage-collaboration@2x-p-800.webp 800w, /images/pages/product_document_workspace-manage-collaboration@2x-p-1080.webp 1080w, /images/pages/product_document_workspace-manage-collaboration@2x.webp 1200w" class="_2-block-image-radius" />
          </div>
          <div data-w-tab="Tab 5" class="w-tab-pane">
            <img width="600" loading="eager" alt="" src="/images/pages/product_document_workspace-manage-3rdparty.svg" class="_2-block-image-radius" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section px-40 why-formx">
    <div class="card-xl full-width green-shape-bg">
      <div class="card-xl-vertical-wrap text-center">
        <div class="card-xl-content-wrap left half-width">
          <h2 class="card-xl-title color-white">Leverage Your Extractors for Streamlined Workflows</h2>
          <div class="card-xl-description color-white pricing">FormX.ai Workspace seamlessly integrates with your custom extractors, allowing you to automate data extraction tasks and maximize efficiency.</div>
          <a href="/products/document-extractor" class="button-secondary color-white mw-260px w-button">Document Extractor -&gt;</a>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section">
    <div class="container-default w-container">
      <div class="home-heading content-center">
        <h2 class="text-center">Seamless Integration for Enhanced Workflows</h2>
        <div class="product-subheading mw-625 text-center">FormX.ai Workspace empowers you to streamline your data extraction across various platforms and services.</div>
      </div>
      <div data-current="Tab 1" data-easing="ease" data-duration-in="300" data-duration-out="100" class="tabs-2 w-tabs">
        <div class="tabs-menu-container-2 w-tab-menu">
          <a data-w-tab="Tab 1" class="home-tabs-menu-2 w-inline-block w-tab-link w--current">
            <div class="home-tabs-menu-title-wrap">
              <div class="home-tabs-menu-title-2">Import</div>
            </div>
          </a>
          <a data-w-tab="Tab 2" class="home-tabs-menu-2 w-inline-block w-tab-link">
            <div class="home-tabs-menu-title-wrap">
              <div class="home-tabs-menu-title-2">Import via Third-Party Services</div>
            </div>
          </a>
          <a data-w-tab="Tab 3" class="home-tabs-menu-2 w-inline-block w-tab-link">
            <div class="home-tabs-menu-title-wrap">
              <div class="home-tabs-menu-title-2">Export</div>
            </div>
          </a>
        </div>
        <div class="w-tab-content">
          <div data-w-tab="Tab 1" class="w-tab-pane w--tab-active">
            <div class="_2-block-flex">
              <div class="_2-block-flex-content">
                <div class="_2-block-flex-content-text-wrap">
                  <div class="_2-block-flex-content-h3">
                    <h3 class="why-formx-tabs h3 text-highlight-green-20">Effortless File Uploads</h3>
                    <div>Drag and drop documents directly from your computer or import them from popular cloud storage services like:</div>
                  </div>
                  <ul role="list" class="_2-block-flex-content-list-3">
                    <li class="_2-block-flex-content-list-item">
                      <div class="why-formx-list-item-title text-highlight-green-20 font-weight-normal">Microsoft SharePoint</div>
                    </li>
                    <li class="_2-block-flex-content-list-item">
                      <div class="why-formx-list-item-title text-highlight-green-20 font-weight-normal">Google Drive</div>
                    </li>
                    <li class="_2-block-flex-content-list-item">
                      <div class="why-formx-list-item-title text-highlight-green-20 font-weight-normal">Dropbox</div>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="_2-block-flex-image-2">
                <img sizes="(max-width: 767px) 100vw, (max-width: 991px) 728px, 940px" srcset="/images/pages/product_document_workspace-workflows-import@2x-p-500.webp 500w, /images/pages/product_document_workspace-workflows-import@2x-p-800.webp 800w, /images/pages/product_document_workspace-workflows-import@2x-p-1080.webp 1080w, /images/pages/product_document_workspace-workflows-import@2x.webp 1200w" alt="" src="/images/pages/product_document_workspace-workflows-import@2x.webp" loading="eager" class="image-rounded" />
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 2" class="w-tab-pane">
            <div class="_2-block-flex">
              <div class="_2-block-flex-content">
                <div class="_2-block-flex-content-text-wrap">
                  <div class="_2-block-flex-content-h3">
                    <h3 class="why-formx-tabs h3 text-highlight-green-20"><strong class="text-highlight-green-20">Zapier and Email</strong></h3>
                    <div>Integrate FormX Workspace with Zapier or configure email triggers to automate document uploads and data extraction based on predefined workflows.</div>
                  </div>
                </div>
              </div>
              <div class="_2-block-flex-image-2">
                <img loading="eager" src="/images/pages/product_document_workspace-workflows-3rdparty.svg" alt="" class="image-rounded" />
              </div>
            </div>
          </div>
          <div data-w-tab="Tab 3" class="w-tab-pane">
            <div class="_2-block-flex">
              <div class="_2-block-flex-content">
                <div class="_2-block-flex-content-text-wrap">
                  <div class="_2-block-flex-content-h3">
                    <h3 class="why-formx-tabs h3 text-highlight-green-20">Export to Excel</h3>
                    <div>Download your extracted data as Excel files for further analysis and integration with your existing spreadsheets.</div>
                  </div>
                  <div class="_2-block-flex-content-h3">
                    <h3 class="why-formx-tabs h3 text-highlight-green-20">Webhook Integration</h3>
                    <div>For a truly automated workflow, send the extracted results directly to an external API upon completion using webhooks.</div>
                  </div>
                </div>
              </div>
              <div class="_2-block-flex-image-2">
                <img loading="eager" src="/images/pages/product_document_workspace-workflows-export.svg" alt="" class="image-rounded" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
