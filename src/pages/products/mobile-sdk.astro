---
import PageLayout from '@/layouts/PageLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
---

<PageLayout
  title="Empower Your Mobile App with Intelligent Document Capture using FormX.ai Mobile SDK"
  description=""
  canonicalUrl="https://www.formx.ai/products/mobile-sdk"
>
  <HeroSection
    heading="Empower Your Mobile App with Intelligent Document Capture using FormX.ai Mobile SDK"
    subheading="FormX.ai's Mobile SDK provides a comprehensive suite of features to seamlessly integrate document scanning functionalities within your mobile application. Our SDK empowers you to capture high-quality document images, improving data extraction accuracy and streamlining the user experience."
    ctaPrimary={{ text: "Talk to Us ->", href: "/schedule-demo" }}
    ctaPrimaryClass="button-white"
    bgClass="bg-green-shapes-v2"
    headingClass="product-hero-content-heading color-white"
    subheadingClass="product-hero-content-subheading color-white"
    image={{
      src: "/images/pages/products_idp-kv.webp",
      alt: "",
      width: 2400,
      height: 1800,
      srcset: "/images/pages/products_idp-kv-p-500.webp 500w, /images/pages/products_idp-kv-p-800.webp 800w, /images/pages/products_idp-kv-p-1080.webp 1080w, /images/pages/products_idp-kv-p-1600.webp 1600w, /images/pages/products_idp-kv-p-2000.webp 2000w, /images/pages/products_idp-kv.webp 2400w",
      sizes: "(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px",
    }}
  />

  <section>
    <div class="w-layout-blockcontainer container-default w-container"></div>
  </section>

  <div class="section product-section">
    <div class="container-default gap-60 w-container">
      <div class="product-heading-wrapper">
        <h2 class="product-heading">Document Detection on Mobile <span class="heading-gradient"><br />Made Easy</span></h2>
        <div class="product-subheading">FormX.ai's Mobile SDK offers a comprehensive suite of features to seamlessly integrate document scanning functionalities into your mobile application.</div>
      </div>
      <div class="product-2-block-wrapper m-reverse">
        <div class="product-2-block-text-wrapper">
          <img src="/images/pages/products_scanmobileSDK_real-time-icon.svg" loading="lazy" alt="" />
          <h2 class="product-2-block-heading">Real-time Document<br />Bounding Box Detection</h2>
          <div class="product-2-block-paragraph">Guide users to capture documents accurately with real-time on-screen overlays highlighting the document's edges.</div>
        </div>
        <div class="product-2-block-image-wrapper">
          <img src="/images/pages/products_scanmobileSDK_real-time@2x.webp" loading="lazy" width="600" sizes="(max-width: 479px) 93vw, (max-width: 767px) 95vw, (max-width: 991px) 44vw, (max-width: 1279px) 45vw, 575.5px" alt="" srcset="/images/pages/products_scanmobileSDK_real-time@2x-p-500.webp 500w, /images/pages/products_scanmobileSDK_real-time@2x-p-800.webp 800w, /images/pages/products_scanmobileSDK_real-time@2x-p-1080.webp 1080w, /images/pages/products_scanmobileSDK_real-time@2x.webp 1200w" />
        </div>
      </div>
      <div class="product-2-block-wrapper reverse">
        <div class="product-2-block-text-wrapper">
          <img src="/images/pages/products_scanmobileSDK_live-preview-icon.svg" loading="lazy" alt="" />
          <h2 class="product-2-block-heading">Live Document Preview</h2>
          <div class="product-2-block-paragraph">Provide users with a live preview of captured documents, ensuring clarity and eliminating the need for retakes.</div>
        </div>
        <div class="product-2-block-image-wrapper">
          <img src="/images/pages/products_scanmobileSDK_live-preview@2x.webp" loading="lazy" width="600" sizes="(max-width: 479px) 93vw, (max-width: 767px) 95vw, (max-width: 991px) 44vw, (max-width: 1279px) 45vw, 575.5px" alt="" srcset="/images/pages/products_scanmobileSDK_live-preview@2x-p-500.webp 500w, /images/pages/products_scanmobileSDK_live-preview@2x-p-800.webp 800w, /images/pages/products_scanmobileSDK_live-preview@2x-p-1080.webp 1080w, /images/pages/products_scanmobileSDK_live-preview@2x.webp 1200w" />
        </div>
      </div>
      <div class="product-2-block-wrapper m-reverse">
        <div class="product-2-block-text-wrapper">
          <img src="/images/pages/products_scanmobileSDK_img-checker-icon.svg" loading="lazy" alt="" />
          <h2 class="product-2-block-heading">Image Quality Check</h2>
          <div class="product-2-block-paragraph">Identify blurry or poorly lit images that might not be suitable for data extraction and prompt users to recapture documents for optimal results.</div>
        </div>
        <div class="product-2-block-image-wrapper">
          <img src="/images/pages/products_scanmobileSDK_img-checker@2x.webp" loading="lazy" width="600" sizes="(max-width: 479px) 93vw, (max-width: 767px) 95vw, (max-width: 991px) 44vw, (max-width: 1279px) 45vw, 575.5px" alt="" srcset="/images/pages/products_scanmobileSDK_img-checker@2x-p-500.webp 500w, /images/pages/products_scanmobileSDK_img-checker@2x-p-800.webp 800w, /images/pages/products_scanmobileSDK_img-checker@2x-p-1080.webp 1080w, /images/pages/products_scanmobileSDK_img-checker@2x.webp 1200w" />
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Unveiling the Power of FormX.ai <span class="heading-gradient">Mobile SDK Features</span></h2>
          <div class="product-subheading">The FormX.ai Mobile SDK offers a robust set of functionalities designed to elevate your mobile app's document capture capabilities. This table provides a detailed breakdown of each feature and its purpose:</div>
        </div>
        <div class="product-content-wrapper">
          <div class="mobile-sdk_table">
            <div class="scan-mobile_table-cell">
              <div class="scan-mobile_table-header"><div>Feature</div></div>
            </div>
            <div class="scan-mobile_table-header"><div>Description</div></div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_65b4fd55-a7a7-3705-5ec0-b13440600dab-3f93e526" class="scan-mobile_table-content"><div>Camera View (Pre-built)</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_7997db64-2e1b-7547-b43e-d4ff25cf24a1-3f93e526" class="scan-mobile_table-content"><div>Provides a user-friendly camera interface specifically optimized for document capture.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_6cf9148d-b155-8db4-ae3d-074fc17abc06-3f93e526" class="scan-mobile_table-content"><div>Detect Document Online</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_6cf9148d-b155-8db4-ae3d-074fc17abc0a-3f93e526" class="scan-mobile_table-content"><div>Uploads the captured image to FormX.ai servers for accurate document detection and cropping.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_05fb769d-7b97-1355-e80d-a7cbf03a699c-3f93e526" class="scan-mobile_table-content"><div>Detect Document Offline</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_05fb769d-7b97-1355-e80d-a7cbf03a69a0-3f93e526" class="scan-mobile_table-content"><div>Utilizes an on-device model for real-time document detection within the camera viewfinder, eliminating the need for an internet connection.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_383c8520-5d96-ae27-e79b-bd9d23a73c27-3f93e526" class="scan-mobile_table-content"><div>Extract Document</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_383c8520-5d96-ae27-e79b-bd9d23a73c2b-3f93e526" class="scan-mobile_table-content"><div>Sends the document image to FormX.ai for data extraction, such as dates or specific information.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_9356b2cc-b5cc-92ea-f80b-dcc0ba6206f3-3f93e526" class="scan-mobile_table-content"><div>Image Proc</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_9356b2cc-b5cc-92ea-f80b-dcc0ba6206f7-3f93e526" class="scan-mobile_table-content"><div>Offers a toolkit for image processing tasks outside the pre-built camera view, enabling customization of the capture experience.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-e444e261-a1cb-a437-f3ad-d8e32f7e3217-3f93e526" class="scan-mobile_table-content"><div>Blur Detector</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-e444e261-a1cb-a437-f3ad-d8e32f7e321b-3f93e526" class="scan-mobile_table-content"><div>Analyzes the captured image and returns a score indicating its level of blurriness, allowing for retakes if necessary.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-cb49bc51-bad9-5fe1-2335-6c801f06aa9b-3f93e526" class="scan-mobile_table-content"><div>FormX Stabilizer</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-cb49bc51-bad9-5fe1-2335-6c801f06aa9f-3f93e526" class="scan-mobile_table-content"><div>Determines camera stability before capturing the image, minimizing blurry results due to camera shake.</div></div>
            </div>
          </div>
          <div class="mobile-sdk_table table-row">
            <div class="scan-mobile_table-cell">
              <div id="w-node-_048f5b37-4898-6ee9-3074-96106cebae26-3f93e526" class="scan-mobile_table-content"><div>Long Receipt Stitching</div></div>
            </div>
            <div class="scan-mobile_table-cell">
              <div id="w-node-_048f5b37-4898-6ee9-3074-96106cebae2a-3f93e526" class="scan-mobile_table-content"><div>Facilitates the capture of high-quality images for lengthy receipts by stitching together multiple frames acquired while moving the camera.</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="section mobile-sdk">
    <div class="w-layout-blockcontainer container-default w-container">
      <div class="_2-block-flex mobile-footer">
        <div class="div-block-3">
          <img src="/images/pages/products_try_app@2x.webp" loading="lazy" width="1433" height="1654" sizes="(max-width: 479px) 94vw, (max-width: 767px) 95vw, (max-width: 991px) 96vw, (max-width: 1279px) 72vw, 716.5px" alt="" srcset="/images/pages/products_try_app@2x-p-500.webp 500w, /images/pages/products_try_app@2x-p-800.webp 800w, /images/pages/products_try_app@2x-p-1080.webp 1080w, /images/pages/products_try_app@2x.webp 1433w" class="mobile-footer_left-image" />
        </div>
        <div class="mobile-footer_right">
          <div class="mobile-footer_right-image">
            <div class="mobile-footer_right_top-image-wrap">
              <img src="/images/pages/products_try_app-icon@2x.webp" loading="lazy" width="80" alt="" />
            </div>
          </div>
          <div class="mobile-footer_right_links">
            <h2 class="mobile-footer_right_content-title">Experience the Power Firsthand: Try our Mobile SDK Demo App!</h2>
            <div class="mobile-footer_right_content-description">We've created intuitive demo apps for both iOS and Android platforms that showcase the functionalities of the FormX.ai Mobile SDK in action.</div>
          </div>
          <div class="mobile-footer_right_links">
            <div class="mobile-footer_right_content-description paragraph-small">Download the app and experiment with features like real-time document detection, image quality analysis, and more!</div>
            <div class="mobile-footer_right_links-inner">
              <div>
                <a href="https://apps.apple.com/us/app/ai-scan-formx/id6444301909" class="w-inline-block">
                  <img src="/images/pages/products_try_app-iOS.svg" loading="lazy" alt="" />
                </a>
              </div>
              <div>
                <a href="https://play.google.com/store/apps/details?id=com.formextractorai.demo.android" class="w-inline-block">
                  <img src="/images/pages/products_try_app-GooglePlay.svg" loading="lazy" alt="" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="footer-translate"></div>
</PageLayout>
