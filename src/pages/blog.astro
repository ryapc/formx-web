---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import GridCard from '@/components/blog/GridCard.astro';
import { getAllPosts, CATEGORY_LABELS, formatDate } from '@/lib/blog';

const allPosts = await getAllPosts();
const allWhatsNew = await getCollection('whatsNew');

// Pinned featured item — whats-new entry takes priority over blog featured flag
const PINNED_WHATS_NEW_ID = '2026-04-16';
const pinnedWhatsNew = allWhatsNew.find((w) => w.id === PINNED_WHATS_NEW_ID);

type FeaturedItem = {
  href: string;
  title: string;
  image: string;
  imageAlt: string;
  badge: string;
  excerpt: string;
  date: Date;
};

const featuredItem: FeaturedItem | undefined = pinnedWhatsNew
  ? {
      href: `/whats-new/${pinnedWhatsNew.id}`,
      title: pinnedWhatsNew.data.title,
      image: pinnedWhatsNew.data.featured_image,
      imageAlt: pinnedWhatsNew.data.title,
      badge: pinnedWhatsNew.data.tag,
      excerpt: pinnedWhatsNew.data.description,
      date: pinnedWhatsNew.data.date,
    }
  : (() => {
      const p = allPosts.find((p) => p.data.featured) ?? allPosts[0];
      return p
        ? {
            href: `/blog/${p.id}`,
            title: p.data.title,
            image: p.data.featured_image,
            imageAlt: p.data.featured_image_alt || p.data.title,
            badge: CATEGORY_LABELS[p.data.category] ?? p.data.category,
            excerpt: p.data.excerpt,
            date: p.data.date,
          }
        : undefined;
    })();

// Build unified grid: all blog posts + all whats-new except the pinned one
type GridItem = {
  href: string;
  title: string;
  image: string;
  imageAlt: string;
  tag: string;
  tagHref: string;
  date: Date;
};

const blogGridItems: GridItem[] = allPosts.map((p) => ({
  href: `/blog/${p.id}`,
  title: p.data.title,
  image: p.data.featured_image,
  imageAlt: p.data.featured_image_alt || p.data.title,
  tag: CATEGORY_LABELS[p.data.category] ?? p.data.category,
  tagHref: `/blog-post-category/${p.data.category}`,
  date: p.data.date,
}));

const whatsNewGridItems: GridItem[] = allWhatsNew
  .filter((w) => w.id !== PINNED_WHATS_NEW_ID)
  .map((w) => ({
    href: `/whats-new/${w.id}`,
    title: w.data.title,
    image: w.data.featured_image,
    imageAlt: w.data.title,
    tag: w.data.tag,
    tagHref: '/whats-new',
    date: w.data.date,
  }));

const gridItems = [...blogGridItems, ...whatsNewGridItems].sort(
  (a, b) => b.date.valueOf() - a.date.valueOf()
);

const categories = Object.entries(CATEGORY_LABELS);
---

<PageLayout
  title="FormX.ai Blog - Document Processing & AI Resources"
  description="Read the latest articles on AI document processing, OCR, invoice automation, and more from the FormX.ai team."
  canonicalUrl="https://www.formx.ai/blog/"
  bodyClass="blog-page"
>
  <div class="section blog-hero">
    <div class="container-default w-container">
      <h1 class="title blog">Blog</h1>

      {/* Featured Post */}
      {featuredItem && (
        <div>
          <a href={featuredItem.href} class="card blog-post-featured-last w-inline-block">
            <div class="card-blog-post-featured-content-last">
              <div class="badge blog-post-featured">
                <div class="text-block-4">{featuredItem.badge}</div>
              </div>
              <h2 class="h3-title-small">{featuredItem.title}</h2>
              <p>{featuredItem.excerpt}</p>
              <div class="divider blog-post-featured"></div>
              <div class="card-blog-post-featured-about-wrapper">
                <div class="card-blog-post-date">{formatDate(featuredItem.date)}</div>
              </div>
            </div>
            <div class="image-wrapper card-blog-post-featured-last">
              <img
                src={featuredItem.image}
                alt={featuredItem.imageAlt}
                class="image card-blog-post-featured-last-image"
                loading="eager"
              />
            </div>
          </a>
        </div>
      )}
    </div>
  </div>

  <div class="top-content latest-posts">
    <div class="container-default w-container">
      <div class="split-content top-latest-posts-left">
        <h2>All Articles</h2>
      </div>

      {/* Category filter tabs */}
      <div class="blog-categories-grid">
        <a href="/blog/" class="button-blog-category all w-button">All</a>
        {categories.map(([slug, label]) => (
          <a href={`/blog-post-category/${slug}/`} class="button-blog-category w-button">
            {label}
          </a>
        ))}
        <a href="/whats-new/" class="button-blog-category w-button">What's New</a>
      </div>
    </div>
  </div>

  <div class="section blog-posts-section">
    <div class="container-default w-container">
      <div class="blog-post-grid">
        {gridItems.map((item) => (
          <GridCard {...item} />
        ))}
      </div>
    </div>
  </div>
</PageLayout>
