                </div>
              </div>
              <div data-w-tab="Tab 3" class="w-tab-pane">
                <div class="_2-block-flex gap-20">
                  <div class="_2-block-flex-content tabs-content">
                    <div class="tabs-content-left mw--515px">
                      <div class="tabs-content-svg"><img loading="lazy" src="/images/pages/why-formx-effortless_on_the_go_icon-03-ux.svg" alt=""/></div>
                      <h3 class="mb-0">Enhanced User Experience</h3>
                      <div>FormX.ai makes document processing mobile-friendly. The intuitive interface ensures a smooth and efficient experience for users capturing documents with their smartphones.</div>
                    </div>
                  </div>
                  <div class="_2-block-flex-image">
                    <img width="600" sizes="(max-width: 767px) 100vw, min(600px, 50vw)" alt="" src="/images/pages/why-formx-effortless_on_the_go_03@2x.webp" loading="eager" srcset="/images/pages/why-formx-effortless_on_the_go_03@2x-p-500.webp 500w, /images/pages/why-formx-effortless_on_the_go_03@2x-p-800.webp 800w, /images/pages/why-formx-effortless_on_the_go_03@2x-p-1080.webp 1080w, /images/pages/why-formx-effortless_on_the_go_03@2x.webp 1200w" class="img-fluid-block"/>
