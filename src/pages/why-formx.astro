          <div class="mask-2 w-slider-mask">
            <div class="slide testimonial w-slide">
              <div class="testimonial-slide card-xl-testimonial-wrap">
                <div class="card-xl-testimonial-icon"><img src="/images/pages/Group-1974.svg" loading="lazy" alt=""/></div>
                <div class="card-xl-testimonial why-formx">&quot;<span class="font-weight-700">Saved tons of time</span> eliminating manual data entry from bills of lading with FormX.ai. It extracts info flawlessly, reducing errors and freeing us for strategic tasks. A game-changer for logistics!&quot;</div>
                <div class="card-xl-testimonial-author-wrap">
                  <div class="card-xl-testimonial-author-photo rounded"><img src="/images/pages/why-formx-result_01-SaraJones@2x.webp" loading="lazy" alt=""/></div>
                  <div class="card-xl-testimonial-author-info-wrap">
                    <div class="card-xl-testimonial-author-info-name testimonial-name">Sarah Jones</div>
