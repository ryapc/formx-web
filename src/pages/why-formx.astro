                <div class="home-tabs-menu-title-content-wrap">
                  <div class="home-tabs-menu-svg-wrap"><img loading="lazy" src="/images/pages/why-formx-effortless_on_the_go_icon-02-increased.svg" alt=""/></div>
                  <div class="home-tabs-menu-title-content-inner">
                    <div class="home-tabs-menu-title">Increased Efficiency</div>
                    <div class="home-tabs-menu-description">No more waiting for documents to upload or transfer.</div>
                  </div>
                </div>
              </a>
              <a data-w-tab="Tab 3" class="home-tabs-menu w-inline-block w-tab-link">
                <div class="home-tabs-menu-title-content-wrap">
                  <div class="home-tabs-menu-svg-wrap"><img loading="lazy" src="/images/pages/why-formx-effortless_on_the_go_icon-03-ux.svg" alt=""/></div>
                  <div class="home-tabs-menu-title-content-inner">
                    <div class="home-tabs-menu-title">Enhanced User Experience</div>
