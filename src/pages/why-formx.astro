                    <img width="600" sizes="(max-width: 767px) 100vw, min(600px, 50vw)" alt="" src="/images/pages/why-formx-effortless_on_the_go_02@2x.webp" loading="eager" srcset="/images/pages/why-formx-effortless_on_the_go_02@2x-p-500.webp 500w, /images/pages/why-formx-effortless_on_the_go_02@2x-p-800.webp 800w, /images/pages/why-formx-effortless_on_the_go_02@2x-p-1080.webp 1080w, /images/pages/why-formx-effortless_on_the_go_02@2x.webp 1200w" class="img-fluid-block"/>
