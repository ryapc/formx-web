<style is:inline>
  /* CSS scroll-snap slider replacement for w-slider */
  .w-slider-mask {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .w-slider-mask::-webkit-scrollbar { display: none; }
  .w-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }
</style>

<script is:inline>
  (function() {
    var mask = document.querySelector('.w-slider-mask');
    if (!mask) return;
    var leftBtn = document.querySelector('.w-slider-arrow-left');
    var rightBtn = document.querySelector('.w-slider-arrow-right');
    function getSlideWidth() {
      var slide = mask.querySelector('.w-slide');
      return slide ? slide.offsetWidth : 0;
    }
    if (leftBtn) {
      leftBtn.addEventListener('click', function() {
        mask.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
      });
    }
    if (rightBtn) {
      rightBtn.addEventListener('click', function() {
        mask.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
      });
    }
  })();
</script>
