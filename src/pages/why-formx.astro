---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="Why FormX"
  description=""
  canonicalUrl="https://www.formx.ai/why-formx"
>
  <!-- Hero -->
  <div class="section hero-page home">
    <div class="container-default w-container">
      <div class="why-formx-hero-wrap hero-centered">
        <div class="why-formx-hero-content-wrap hero-centered">
          <div class="hero-title-small-label">Why FormX</div>
          <h1 class="hero-centered h1">Document Processing Evolved: <br/>FormX.ai - Your Flexible, API-Powered Future</h1>
          <p class="heading-centered description"><span class="text-highlight text-color-primary">Transform the way you process documents!</span> FormX.ai's intelligent document extraction unlocks a world of possibilities. Our API-first solution seamlessly integrates with any existing system, streamlining your entire document processing workflow.</p>
        </div>
        <a href="/schedule-demo" class="button-primary w-button">Schedule Demo -&gt;</a>
      </div>
    </div>
  </div>

  <!-- AI accuracy section -->
  <div class="section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Unleash the Power of AI for Unmatched Accuracy</h2>
          <div class="product-subheading">FormX.ai leverages the cutting edge of Artificial Intelligence to revolutionize your document processing. We've integrated the power of Large Language Models (LLMs) like GPT-3 to deliver unmatched accuracy in data extraction.</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card card-bg-white card-content-center pb-0">
              <div class="card-svg-block">
                <img src="/images/pages/solutions_retails-icon-1.svg" loading="lazy" width="80" alt="" class="card-svg small"/>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Superior Accuracy with LLMs</div>
                <div class="svg-card-description">Our integration with GPT technology unlocks a new level of precision. LLMs can understand complex language nuances, leading to significantly fewer errors and a higher return on investment.</div>
              </div>
            </div>
            <div id="w-node-e7de0139-e3ae-6b9a-ab5b-afa856de6e58-d52a5528" class="plain-svg-card card-bg-white card-content-center pb-0">
              <div class="card-svg-block">
                <img src="/images/pages/solutions_retails-icon-2.svg" loading="lazy" width="80" alt="" class="card-svg small"/>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Effortless Model Training</div>
                <div class="svg-card-description">No coding expertise required! FormX.ai's intuitive interface allows you to train custom models with just a few sample documents. This ensures your AI precisely extracts the information you need.</div>
              </div>
            </div>
            <div id="w-node-e7de0139-e3ae-6b9a-ab5b-afa856de6e60-d52a5528" class="plain-svg-card card-bg-white card-content-center pb-0">
              <div class="card-svg-block">
                <img src="/images/pages/solutions_retails-icon-3.svg" loading="lazy" width="80" alt="" class="card-svg small"/>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Intelligent Automation</div>
                <div class="svg-card-description">AI automates repetitive tasks, freeing up your team's valuable time. Focus on strategic initiatives while FormX.ai handles the document processing heavy lifting, allowing you to work smarter, not harder.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile capture tabs section -->
  <div class="section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Effortless On-the-Go Processing: &#x2028;Mobile Capture with Instant Results</h2>
