---
import PageLayout from '@/layouts/PageLayout.astro';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
---

<PageLayout
  title="Easily Automate Form Extraction with Zapier &amp; N8N"
  description=""
  canonicalUrl="https://www.formx.ai/solutions/zapier-and-n8n"
  showFooterForm={true}
>
  <div class="section product-hero bg-green-shapes-v2">
    <div class="container-default w-container">
      <div class="product-hero-wrapper">
        <div class="hero-content-block">
          <div class="product-hero-content-wrapper">
            <div class="hero-title-tag">FormX.ai + Zapier/n8n Integration</div>
            <h1 class="product-hero-content-heading color-white product">Unleash Automation Superpowers: FormX.ai + Zapier/n8n Integration</h1>
            <div class="product-hero-content-subheading color-white">Effortlessly extract data from Google Drive documents and import it directly into your online spreadsheets.</div>
            <a href="/schedule-demo" class="button-primary button-white button-left w-button">See a Demo -&gt;</a>
          </div>
        </div>
        <div class="hero-image-block">
          <img src="/images/pages/products_zapier-n8n-integration-kv.svg" loading="lazy" width="515" height="515" alt="" class="image-7" />
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Break Free from Manual Work:<br/><span class="heading-gradient">Automate Your Document Workflow</span></h2>
          <div class="product-subheading">With Zapier or n8n integration, you can transform time-consuming tasks into automated processes.</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card card-bg-white card-content-center p-0 m-16 bordered first">
              <div class="card-svg-block svg-center flex-center">
                <div class="steps-number">1</div>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Effortless Automation</div>
                <div class="svg-card-description">Zapier and n8n's intuitive interface lets you build automated workflows in minutes, freeing you up for more strategic work.</div>
              </div>
            </div>
            <div class="plain-svg-card card-bg-white card-content-center p-0">
              <div class="card-svg-block svg-center flex-center">
                <div class="steps-number">2</div>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Supercharge Your Data Extraction</div>
                <div class="svg-card-description">FormX.ai's fine-tuned AI tackles even the most complex documents, ensuring accurate data extraction every time.</div>
              </div>
            </div>
            <div class="plain-svg-card card-bg-white card-content-center p-0 m-16 bordered last">
              <div class="card-svg-block svg-center flex-center">
                <div class="steps-number">3</div>
              </div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Seamless Integration</div>
                <div class="svg-card-description">Connect seamlessly with your favorite Google Workspace apps to streamline your data flow.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section">
    <div class="container-default gap-32 w-container">
      <div class="product-heading-wrapper">
        <h2 class="product-heading">Supercharge Your<br/><span class="heading-gradient">Google Workspace with Automation</span></h2>
        <div class="product-subheading">Transform your Google Workspace into a data powerhouse by automating document processing and data transfer.</div>
      </div>
      <div class="product-2-block-wrapper reverse">
        <div class="product-2-block-image-wrapper">
          <img src="/images/pages/products_zapier-n8n-integration-automation-googledrive.svg" loading="lazy" alt="" class="_2-block-image-radius" />
        </div>
        <div class="product-2-block-text-wrapper">
          <h2 class="product-2-block-heading">Auto Extract Documents from Google Drive</h2>
          <div class="product-2-block-paragraph">Automatically feed your documents into the FormX.ai pipeline directly from Google Drive. No more wasted time searching for files or transferring them between platforms.</div>
        </div>
      </div>
      <div class="product-2-block-wrapper m-reverse">
        <div class="product-2-block-image-wrapper">
          <img src="/images/pages/products_zapier-n8n-integration-automation-autoimport.svg" loading="lazy" alt="" class="_2-block-image-radius" />
        </div>
        <div class="product-2-block-text-wrapper">
          <h2 class="product-2-block-heading">Auto Import Extracted Data into Online Spreadsheet</h2>
          <div class="product-2-block-paragraph">Effortlessly populate your online spreadsheets with the data extracted from your documents.</div>
        </div>
      </div>
    </div>
  </div>

  <FeatureGrid
    heading="Why FormX.ai? The Secret Weapon of Your Automation"
    subheading="Not all document processing solutions are created equal. Here's what sets FormX.ai apart"
    columns={4}
    cards={[
      {
        icon: "/images/pages/products_zapier-n8n-integration-automation-whyformx-ai.svg",
        iconWidth: 128,
        iconClass: "xs",
        title: "Fine-tuned AI",
        description: "Our AI goes beyond basic OCR, intelligently understanding the context and structure of your documents."
      },
      {
        icon: "/images/pages/products_zapier-n8n-integration-automation-whyformx-accuracy.svg",
        iconWidth: 128,
        iconClass: "xs",
        title: "Unmatched Accuracy",
        description: "Extract data with exceptional accuracy, minimizing errors and ensuring reliable information."
      },
      {
        icon: "/images/pages/products_zapier-n8n-integration-automation-whyformx-complex.svg",
        iconWidth: 128,
        iconClass: "xs",
        title: "Complex Document Handling",
        description: "Tackle even the most challenging documents with intricate layouts or mixed content."
      },
      {
        icon: "/images/pages/products_zapier-n8n-integration-automation-whyformx-integration.svg",
        iconWidth: 128,
        iconClass: "xs",
        title: "Seamless Integration",
        description: "Connects effortlessly with Zapier and n8n, allowing for a smooth workflow within your existing tools."
      }
    ]}
  />
</PageLayout>
