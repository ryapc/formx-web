---
import PageLayout from '@/layouts/PageLayout.astro';
import CTACard from '@/components/sections/CTACard.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import StatCard from '@/components/sections/StatCard.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
import ClientLogosBar from '@/components/sections/ClientLogosBar.astro';
---

<PageLayout
  title="PAYG Extractor - Free Tool to Extract Australian Payment Summary Data | FormX.ai"
  description="Free PAYG Payment Summary extractor. Upload any ATO PAYG form and get employer ABN, employee TFN, gross wages, and PAYG withholding as JSON or CSV - no signup required."
  canonicalUrl="https://www.formx.ai/tools/payg-extractor/"
  showFooterForm={true}
>
  <section class="title-2 bg-f7f8fc">
    <div class="w-layout-blockcontainer pagetitle__container w-container">
      <h1 class="pricing-title"><span class="heading-gradient">PAYG Extractor<br/>‍</span>Free Tool to Extract Australian Payment Summary Data</h1>
      <p class="section__header__content">Upload any ATO PAYG Payment Summary and get <span class="text-span-25">structured data back in seconds</span>. Free to try, no signup required. FormX reads employer ABN, employee TFN, gross wages, and total PAYG withholding - returned as JSON or CSV instantly, ready to use in any tax or accounting system.</p>
      <div class="w-embed w-iframe">
        <iframe src="https://tools.formx.ai/embed/payg" style="width: 100%; height: 600px" frameBorder="0"></iframe>
      </div>
    </div>
  </section>

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container min-w-0 max-w-full">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">What is a PAYG Payment Summary?</h2>
          <div class="product-subheading">
            A PAYG Payment Summary (ATO form NAT 0046) is the document Australian employers issue to employees at the end of each income year, reporting gross wages paid and total PAYG withholding deducted. It is the Australian equivalent of the US W-2 and UK P60 - same function, different issuer. Most employers migrated to Single Touch Payroll (STP) income statements from the 2018-19 income year, but PAYG summaries remain in use for prior-year records, closely-held payees, and employers not covered by mandatory STP reporting.
          </div>
          <div class="product-subheading" style="margin-top:16px">
            FormX extracts data from both PAYG Payment Summaries and STP income statements. Upload a PDF, JPG, or PNG and get every field back as structured data - no manual entry, no templates.
          </div>
          <a href="/schedule-demo/" class="inter-tight link-semibold text-highlight-green-20" style="margin-top:16px;display:inline-block">Get in touch →</a>
        </div>
      </div>
    </div>
  </div>

  <HowItWorks
    tightPadding
    heading="How to Extract Data from a PAYG Payment Summary"
    subheading="Three steps to turn your PAYG Payment Summary into structured data. No account needed to try it."
    steps={[
      {
        icon: '/images/tools/icons/paper-upload.svg',
        title: 'Upload',
        description: 'Drop your PAYG Payment Summary PDF, JPG, or PNG into the tool above. Scanned copies, phone photos, and digital PDFs from MYOB, Xero, Employment Hero, and KeyPay all work.',
      },
      {
        icon: '/images/tools/icons/swap.svg',
        title: 'Extract',
        description: 'FormX AI reads every field - ABN, TFN, gross income, total tax withheld, reportable fringe benefits - and validates the values for consistency.',
      },
      {
        icon: '/images/tools/icons/paper-download.svg',
        title: 'Download',
        description: 'Get your data as Excel or JSON. Ready to import into your tax software, lodge with the ATO, or feed into any accounting workflow.',
      },
    ]}
  />

  <FeatureGrid
    tightPadding
    heading="Who Uses the PAYG Extractor"
    columns={3}
    bgClass="bg-f7f8fc"
    cards={[
      {
        icon: '/images/tools/icons/icon-accounting.svg',
        title: 'Tax Agents and BAS Agents',
        description: 'Australian tax agents preparing individual income tax returns receive PAYG summaries from dozens of clients each year. FormX extracts all fields instantly and feeds figures directly into tax preparation software.',
      },
      {
        icon: '/images/tools/icons/icon-mortgage.svg',
        title: 'Mortgage and Home Loan Applications',
        description: 'Australian lenders require PAYG summaries as proof of income. FormX lets brokers and lenders verify borrower income instantly without manual data entry.',
      },
      {
        icon: '/images/tools/icons/icon-hr.svg',
        title: 'HR and Payroll Teams',
        description: 'HR teams verifying historical earnings or reissuing lost summaries use FormX to extract PAYG data from archived PDFs without reopening payroll records.',
      },
      {
        icon: '/images/tools/icons/icon-banking.svg',
        title: 'Financial Services and Banking',
        description: 'Banks and non-bank lenders use PAYG withholding data to verify income for personal loans and credit decisions. FormX integrates directly into underwriting workflows.',
      },
      {
        icon: '/images/tools/icons/icon-screening.svg',
        title: 'Rental and Income Verification',
        description: 'Property managers and landlords use PAYG summaries to verify prospective tenant income. FormX automates extraction at scale across high-volume referencing workflows.',
      },
    ]}
  />

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container min-w-0 max-w-full">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">PAYG Payment Summary vs W-2 vs P60</h2>
          <div class="product-subheading">
            All three are annual employer-issued tax forms that summarise employee income and tax withheld - but they are issued in different countries under different tax authorities.
          </div>
          <div class="product-subheading" style="margin-top:16px">
            <strong>PAYG Payment Summary (Australia)</strong> - Issued by Australian employers under the ATO's PAYG withholding system. Reports gross wages and total tax withheld for the Australian income year (1 July to 30 June). Most employers now use STP income statements instead.
          </div>
          <div class="product-subheading" style="margin-top:16px">
            <strong>W-2 (United States)</strong> - Issued by US employers to employees by 31 January each year. Reports wages, federal and state tax withholdings, Social Security, Medicare, and Box 12 codes for the US calendar year.
          </div>
          <div class="product-subheading" style="margin-top:16px">
            <strong>P60 (United Kingdom)</strong> - Issued by UK employers to employees by 31 May each year. Reports total pay, income tax deducted, and National Insurance contributions for the UK tax year (6 April to 5 April).
          </div>
          <div class="product-subheading" style="margin-top:16px">
            FormX extracts data from all three. If you process payroll tax documents across multiple countries, FormX handles them in a single workflow.
          </div>
          <div style="margin-top:16px;display:flex;gap:12px;flex-wrap:wrap;">
            <a href="/tools/w2-extractor/" class="inter-tight link-semibold text-highlight-green-20">W-2 Extractor →</a>
            <a href="/tools/p60-converter/" class="inter-tight link-semibold text-highlight-green-20">P60 Converter →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <ClientLogosBar />

  <CTACard
    heading="Try the PAYG Extractor free today"
    bgClass="bg-f7f8fc"
    ctaPrimary={{ text: "Start Free Trial", href: "https://formextractorai.com/signup" }}
    ctaSecondary={{ text: "Speak with an Expert ->", href: "/schedule-demo" }}
  />

  <FAQSection
    heading="Frequently Asked Questions"
    items={[
      {
        question: "Is the PAYG extractor free to use?",
        answer: `Yes. You can upload a PAYG Payment Summary and extract the data right now with no account or signup. The free tier supports single-document extraction. Batch processing and API access are available with a FormX account. <a href="/schedule-demo/">Get in touch</a> if you need bulk processing.<br />`,
      },
      {
        question: "What is a PAYG Payment Summary?",
        answer: `A PAYG Payment Summary (ATO form NAT 0046) is the document Australian employers issue at the end of each income year. It reports the employee's gross wages and the total PAYG withholding deducted by the employer. From 2018-19, most employers switched to Single Touch Payroll (STP) income statements, but PAYG summaries remain in use for prior years and certain employer categories.<br />`,
      },
      {
        question: "What fields does FormX extract from a PAYG Payment Summary?",
        answer: `FormX extracts: employer name and ABN, employee name and TFN, gross payment, total tax withheld, reportable fringe benefits amount, reportable employer super contributions, tax file number declaration date, and the income year. <a href="/schedule-demo/">Schedule a Demo</a> to see it in action.<br />`,
      },
      {
        question: "What file formats does the PAYG extractor accept?",
        answer: `PDF, JPG, and PNG. This includes scanned paper PAYG summaries, phone photographs, and digitally generated PDFs from MYOB, Xero, Employment Hero, KeyPay, and Micropay.<br />`,
      },
      {
        question: "Does FormX support STP income statements as well as PAYG summaries?",
        answer: `Yes. FormX processes both traditional PAYG Payment Summary forms (NAT 0046) and income statements generated through Single Touch Payroll (STP), which replaced paper summaries for most employers from the 2018-19 income year.<br />`,
      },
      {
        question: "Is it safe to upload PAYG Payment Summaries?",
        answer: `FormX is ISO 27001 and SOC 2 Type II certified. All uploaded documents are encrypted in transit (TLS 1.2+) and at rest (AES-256). Documents are not retained after extraction. Read our <a href="/data-privacy-policy/" target="_blank">data privacy policy</a> for more.<br />`,
      },
      {
        question: "Can FormX extract PAYG data via API?",
        answer: `Yes. FormX provides a REST API that accepts PAYG Payment Summary PDFs and returns structured JSON - suitable for integration with tax software, accounting systems, and mortgage origination platforms. See our <a href="https://help.formx.ai/reference/document-extraction">API documentation</a>.<br />`,
      },
      {
        question: "What is the difference between a PAYG summary and a Group Certificate?",
        answer: `A Group Certificate was the older name for what is now called a PAYG Payment Summary. The ATO renamed the form when the PAYG withholding system was introduced in 2000. FormX extracts data from both formats, including older Group Certificate layouts.<br />`,
      },
      {
        question: "How is a PAYG Payment Summary different from a W-2 or P60?",
        answer: `All three are annual employer-issued tax forms reporting income and tax withheld. A PAYG Payment Summary is the Australian version (ATO, income year 1 July to 30 June). A W-2 is the US equivalent (IRS, calendar year). A P60 is the UK equivalent (HMRC, tax year 6 April to 5 April). FormX extracts data from all three.<br />`,
      },
    ]}
  />

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">Extract PAYG Data Automatically with FormX</h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <StatCard number="10x" label="Productivity" description="Replace manual PAYG data entry with FormX to automate extraction across all fields and improve productivity by 10 times." />
            <StatCard number=">95%" label="Accuracy" description="FormX delivers 95%+ accuracy on PAYG Payment Summaries across MYOB, Xero, Employment Hero, and KeyPay layouts, reducing manual review to a minimum." />
            <StatCard number="3" label="Months" description="On average, businesses can realise the return on investment of automation in as little as 3 months after implementing FormX.ai." />
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="bg-f7f8fc"></section>
</PageLayout>
