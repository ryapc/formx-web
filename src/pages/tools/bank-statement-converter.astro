---
import PageLayout from '@/layouts/PageLayout.astro';
import CTACard from '@/components/sections/CTACard.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import StatCard from '@/components/sections/StatCard.astro';
---

<PageLayout
  title="Bank Statement Converter | Convert Bank Statement PDF to CSV"
  description="Convert bank statement PDFs to Excel, CSV, or JSON. Extracts account details, balances, and every transaction from any bank layout — no templates, API available."
  canonicalUrl="https://www.formx.ai/tools/bank-statement-converter/"
  showFooterForm={true}
>
  <section class="title-2 bg-f7f8fc">
    <div class="w-layout-blockcontainer pagetitle__container w-container">
      <h1 class="pricing-title">Bank Statement Converter</h1>
      <p class="section__header__content">Convert bank statement PDFs to Excel, CSV, or JSON via API or web upload. FormX extracts account holder details, opening and closing balances, and every transaction — date, description, debit, credit — from any bank layout, without templates.</p>
      <div class="w-embed w-iframe">
        <iframe src="https://widgets.formx.ai/bank-statement" style="width: 100%; height: 600px" frameBorder="0"></iframe>
      </div>
    </div>
  </section>

  <CTACard
    heading="Get started with FormX.ai"
    ctaPrimary={{ text: "Start Free Trial", href: "https://formextractorai.com/signup" }}
    ctaSecondary={{ text: "Speak with an Expert ->", href: "/schedule-demo" }}
  />

  <FAQSection
    heading="Frequently Asked Questions"
    items={[
      {
        question: "What data does FormX extract from a bank statement?",
        answer: `FormX extracts account holder name and address, account number, statement period, opening and closing balances, and a full transaction list — date, description, debit amount, credit amount, and running balance for every row. Output is available as Excel, CSV, or JSON. <a href="/schedule-demo/">Get in touch</a> to see a live demo.<br />`,
      },
      {
        question: "What is the best bank statement OCR API?",
        answer: `The FormX bank statement API extracts transaction data from any bank layout — including multi-page statements, scanned PDFs, and image uploads — and returns structured JSON with account info, statement period, and a full transaction list. No templates or bank-specific configuration required. <a href="https://help.formx.ai/reference/document-extraction" target="_blank">View API documentation</a>.<br />`,
      },
      {
        question: "Which banks and statement formats does FormX support?",
        answer: `FormX is template-free and processes statements from any bank — US, UK, EU, and APAC. It handles multi-column layouts, multi-page PDFs, and statements exported as images. There is no list of supported banks because FormX reads content, not templates. <a href="/schedule-demo/">Contact us</a> to test a specific format.<br />`,
      },
      {
        question: "How does FormX compare to DocuClipper for bank statement conversion?",
        answer: `Both convert bank statements to structured data. FormX is API-first and built for lending platforms, mortgage brokers, and accounting software that need programmatic access and direct system integration — not just file downloads. <a href="/schedule-demo/">Schedule a demo</a> to see the API in action.<br />`,
      },
      {
        question: "Who uses bank statement conversion APIs?",
        answer: `Mortgage lenders verifying income and cash flow, fintech apps automating expense categorisation, accounting firms processing client statements in bulk, and lending platforms running affordability checks. FormX integrates with Xero, QuickBooks, Sage, and custom systems via REST API.<br />`,
      },
      {
        question: "Is the bank statement converter free to use?",
        answer: `Yes — the web tool is free with no signup required. Batch processing and API access are available on a free trial account. <a href="https://formextractorai.com/signup" target="_blank">Sign up</a> or <a href="/schedule-demo/">contact us</a> to get started.<br />`,
      },
    ]}
  />

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Make Your Bank Statement Conversion Intelligent and Automated with FormX</h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <StatCard number="10x" label="Productivity" description="Replace manual data entry with FormX to automate data extraction and improve productivity by 10 times." />
            <StatCard number="92%" label="Accuracy" description="Our proprietary image pre-processing and OCR result post-processing ensure a 92% extraction accuracy, minimizing the need for human intervention." />
            <StatCard number="6" label="Months" description="On average, businesses can realize the return on investment (ROI) of business automation within 6 months after implementing FormX.ai." />
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="bg-f7f8fc"></section>
</PageLayout>
