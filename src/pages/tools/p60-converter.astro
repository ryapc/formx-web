---
import PageLayout from '@/layouts/PageLayout.astro';
import CTACard from '@/components/sections/CTACard.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import StatCard from '@/components/sections/StatCard.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
import ApiResponseExample from '@/components/sections/ApiResponseExample.astro';
import ClientLogosBar from '@/components/sections/ClientLogosBar.astro';
---

<PageLayout
  title="P60 Converter - Convert P60 Data Instantly | FormX.ai"
  description="P60 extraction API and OCR SDK. Extract total pay, tax deducted, NI contributions, and employer details from any HMRC P60 — returned as JSON or CSV instantly."
  canonicalUrl="https://www.formx.ai/tools/p60-converter/"
  showFooterForm={true}
>
  <section class="title-2 bg-f7f8fc">
    <div class="w-layout-blockcontainer pagetitle__container w-container">
      <h1 class="pricing-title"><span class="heading-gradient">P60 Converter<br/>‍</span>P60 Extraction API and OCR SDK — Pull Every Field Automatically</h1>
      <p class="section__header__content"><span class="text-span-26">Use the FormX P60 extraction API or OCR SDK to read HMRC P60 forms instantly.</span> Returns total pay, tax deducted, National Insurance contributions, NI category, statutory payments, and employer PAYE reference as <span class="text-span-25">structured JSON or CSV</span> — no templates required.</p>
      <div class="w-embed w-iframe">
        <iframe src="https://tools.formx.ai/embed/p60" style="width: 100%; height: 600px" frameBorder="0"></iframe>
      </div>
    </div>
  </section>

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container min-w-0 max-w-full">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">What does this P60 Converter do?</h2>
          <div class="product-subheading">
            This P60 converter reads UK HMRC Form P60 and automatically extracts and converts every field into structured data. No manual data entry required. FormX uses OCR and AI to return total pay, tax deducted, and National Insurance figures as Excel or JSON in seconds.
          </div>
          <div class="product-subheading" style="margin-top:16px">
            Need P45, P11D, or P60(Sub) extraction too? FormX supports all HMRC payroll forms.
          </div>
          <a href="/schedule-demo/" class="inter-tight link-semibold text-highlight-green-20" style="margin-top:16px;display:inline-block">Get in touch →</a>
        </div>
      </div>
    </div>
  </div>

  <HowItWorks
    tightPadding
    heading="How the P60 Converter Works"
    subheading="FormX P60 Converter reads your P60 and pulls out every field automatically — no typing, no spreadsheet setup, no manual cross-checking. Upload your form and get your data back in seconds, ready to download or share."
    steps={[
      {
        icon: '/images/tools/icons/paper-upload.svg',
        title: 'Upload',
        description: 'Drop your P60 PDF, JPG, or PNG into the tool. Scanned copies, phone photos, and digital PDFs all work.',
      },
      {
        icon: '/images/tools/icons/swap.svg',
        title: 'Extraction',
        description: 'FormX AI reads the form, identifies each field, and validates the values for consistency.',
      },
      {
        icon: '/images/tools/icons/paper-download.svg',
        title: 'Download',
        description: 'Get your structured data as Excel or JSON — ready to import into your accounting software, mortgage application, or payroll system.',
      },
    ]}
  />

  <FeatureGrid
    tightPadding
    bgClass="bg-f7f8fc"
    heading="Use Cases"
    columns={3}
    cards={[
      {
        icon: '/images/tools/icons/icon-freelancer.svg',
        title: 'Mortgage & Remortgage Applicants',
        description: 'Lenders require P60s as proof of income for mortgage applications. FormX lets applicants upload their P60 and extract key figures instantly — total pay and tax deducted — in the exact format brokers and lenders need.',
      },
      {
        icon: '/images/tools/icons/icon-accounting.svg',
        title: 'Accounting & Tax Firms',
        description: 'Accountants preparing self-assessment tax returns receive P60s from clients every April. FormX converts P60 PDFs into structured data and feeds figures directly into tax preparation software.',
      },
      {
        icon: '/images/tools/icons/icon-hr.svg',
        title: 'HR & Payroll Teams',
        description: 'HR teams verifying historical earnings or handling employee queries about previous tax years use FormX to extract P60 data from archived PDFs without manually reopening payroll records.',
      },
      {
        icon: '/images/tools/icons/icon-gig-worker.svg',
        title: 'Lettings & Rental Applications',
        description: 'Letting agents and landlords request P60s as proof of income from prospective tenants. FormX integrates into referencing workflows to automatically extract and verify income figures at scale.',
      },
      {
        icon: '/images/tools/icons/icon-banking.svg',
        title: 'Financial Services & Banking',
        description: "Banks and lenders use P60 data to verify income for personal loans, credit decisions, and account opening. FormX's API integrates directly into underwriting workflows to extract and validate P60 income data automatically.",
      },
    ]}
  />

  <ApiResponseExample
    tightPadding
    imageSrc="/images/tools/examples/p60-json-example.svg"
    imageAlt="P60 API JSON response example"
  />

  <ClientLogosBar />

  <CTACard
    heading="Get started with FormX.ai"
    bgClass="bg-f7f8fc"
    ctaPrimary={{ text: "Start Free Trial", href: "https://formextractorai.com/signup" }}
    ctaSecondary={{ text: "Speak with an Expert ->", href: "/schedule-demo" }}
  />

  <FAQSection
    heading="Frequently Asked Questions"
    items={[
      {
        question: "What does this P60 converter do?",
        answer: `A P60 converter is a tool that automatically reads HMRC Form P60 and converts every field - total pay, tax deducted, National Insurance contributions, and employer details - into structured data without manual entry. FormX uses OCR and AI to convert P60 data into Excel or JSON in seconds. <a href="/schedule-demo/">Get in touch</a> to learn more!<br />`,
      },
      {
        question: "What P60 fields does FormX extract?",
        answer: `FormX converts all standard P60 fields including employee name and NI number, employer name and PAYE reference, total pay, total tax deducted, employee and employer NI contributions, NI category letter, statutory payments, and student loan deductions. <a href="/schedule-demo/">Schedule a Demo</a> to see how simple it is to automate P60 form extraction.<br />`,
      },
      {
        question: "What file formats does the P60 converter accept?",
        answer: `FormX accepts PDF, JPG, and PNG. This includes scanned paper P60s, photographs taken on a phone, and digitally generated PDFs from payroll software such as Sage, Xero, QuickBooks, and ADP. <a href="/schedule-demo/">Contact us</a> for integrating with different tools to automate your process.<br />`,
      },
      {
        question: "Is it free to convert P60 data?",
        answer: `Yes - the free tier allows single P60 conversion with no signup required. Batch processing of multiple P60s and API access require a free trial account. <a href="/schedule-demo/">Reach out to us</a> and we can setup a demo account for you.<br />`,
      },
      {
        question: "Is it safe to upload P60 forms?",
        answer: `FormX is ISO 27001 and SOC 2 Type II certified. All uploaded documents are encrypted in transit (TLS 1.2+) and at rest (AES-256). Documents are not retained after conversion. Read our <a href="/data-privacy-policy/" target="_blank">data privacy policy</a> for more.<br />`,
      },
      {
        question: "Can FormX extract P60 data via API for batch processing?",
        answer: `Yes. FormX provides a REST API that accepts P60 PDFs and returns structured JSON - making it a P60 extractor suitable for enterprise integration. The API connects with Sage, Xero, Workday, BambooHR, Microsoft Dynamics 365, Zapier, and N8N. API documentation is available at <a href="https://help.formx.ai/reference/document-extraction">here</a>. You can also customise extracted fields through the FormX portal.<br />`,
      },
      {
        question: "What is the difference between a P60 and a P45?",
        answer: `A P60 is issued by your employer at the end of each tax year (5 April) and summarises your total pay and tax for that year. A P45 is issued when you leave a job and shows your pay and tax up to your leaving date. FormX can process both document types.<br />`,
      },
      {
        question: "Can I tailor what I need to extract from P60 forms?",
        answer: `Yes. FormX lets you customise exactly which fields to extract and how the output is structured.<br /><br /><a href="/schedule-demo/">Contact us</a> to setup a trial account for you.<br />`,
      },
      {
        question: "Is there an API for extracting P60 data?",
        answer: `Yes. The FormX P60 extraction API accepts PDF and image uploads and returns all HMRC P60 fields as structured JSON — employee name, NI number, employer PAYE reference, total pay, tax deducted, NI contributions by category, statutory payments, and student loan deductions. Integrates with Sage, Xero, BambooHR, Workday, and Microsoft Dynamics 365. <a href="/schedule-demo/">Get in touch</a> to set up API access.<br />`,
      },
      {
        question: "What is a P60 OCR SDK?",
        answer: `A P60 OCR SDK lets you embed P60 data reading directly into your application without sending documents to a web interface. FormX provides SDKs for Python, Node.js, Java, and .NET. See our <a href="https://help.formx.ai/reference/document-extraction" target="_blank">API documentation</a> to get started.<br />`,
      },
      {
        question: "What is the difference between a P60 converter and a P60 extraction API?",
        answer: `A P60 converter outputs a file (Excel or CSV) for manual use. A P60 extraction API returns structured JSON you can feed directly into payroll software, HR systems, or tax platforms without any manual reformatting. FormX supports both use cases.<br />`,
      },
      {
        question: "What is P60 document AI?",
        answer: `P60 document AI refers to using machine learning and large language models to understand and extract structured data from HMRC P60 forms — going beyond simple OCR to correctly identify fields regardless of layout or formatting differences between payroll software providers. FormX uses this approach to achieve >95% accuracy across Sage, Xero, QuickBooks, and ADP-generated P60s.<br />`,
      },
    ]}
  />

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">Extract P60 Data Automatically with FormX</h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <StatCard number="10x" label="Productivity" description="Replace manual P60 data entry with FormX to automate extraction across all fields and improve productivity by 10 times." />
            <StatCard number=">95%" label="Accuracy" description="FormX delivers 95%+ accuracy on P60 forms across Sage, Xero, QuickBooks, and ADP layouts, reducing manual review to a minimum." />
            <StatCard number="3" label="Months" description="On average, businesses can realise the return on investment of automation in as little as 3 months after implementing FormX.ai." />
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="bg-f7f8fc"></section>
</PageLayout>
