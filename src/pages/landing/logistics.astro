---
import PageLayout from '@/layouts/PageLayout.astro';
import { DEMO_CALENDLY_URL } from '@/lib/constants';
---

<PageLayout
  title="Simplify & Automate Your Logistics Operations | FormX.ai"
  description="Automate document processing and eliminate manual tasks—save time, reduce errors, and streamline your workflow."
  canonicalUrl="https://www.formx.ai/landing/logistics/"
  showFooterForm={true}
>
  <div class="section product-hero bg-logistic">
    <div class="container-default w-container">
      <div class="product-hero-wrapper">
        <div class="hero-content-block">
          <div class="product-hero-content-wrapper">
            <h1 class="product-hero-content-heading inverse">
              Simplify &amp; Automate Your Logistics Operations<br />
              Say Goodbye to Manual Data Entry with FormX
            </h1>
            <div class="product-hero-content-subheading inverse">
              Automate document processing and eliminate manual tasks—save time, reduce errors, and streamline your workflow.
            </div>
          </div>
        </div>
        <div class="hero-image-block hero-form-block">
          <div class="w-form">
            <form
              id="wf-form-Hero-Form"
              name="schedule-demo"
              netlify
              netlify-honeypot="bot-field"
              data-redirect={DEMO_CALENDLY_URL}
              method="post"
              class="form-3"
            >
              <input type="hidden" name="form-name" value="schedule-demo" />
              <input type="hidden" name="source" value="landing-logistics" />
              <p style="display:none"><label>Don't fill this out: <input name="bot-field" type="text" /></label></p>
              <div class="w-layout-blockcontainer container-1470 w-container">
                <label for="hero-Name" class="form-label">Full Name<span class="get-demo-form-label-required">*</span></label>
                <input
                  class="form-text-field w-input"
                  maxlength="256"
                  name="Name"
                  data-name="Name"
                  placeholder=""
                  type="text"
                  id="hero-Name"
                  autocomplete="name"
                  required
                />
              </div>
              <div class="w-layout-blockcontainer container-1472 w-container">
                <label for="hero-Email" class="form-label">Work Email<span class="get-demo-form-label-required">*</span></label>
                <input
                  class="form-text-field w-input"
                  maxlength="256"
                  name="Email"
                  data-name="Email"
                  placeholder=""
                  type="email"
                  id="hero-Email"
                  autocomplete="email"
                  required
                />
              </div>
              <div class="w-layout-blockcontainer container-1473 w-container">
                <label for="hero-pages" class="form-label">How many pages do you wish to process per month?<span class="get-demo-form-label-required">* </span></label>
                <input
                  class="form-text-field w-input"
                  maxlength="256"
                  name="pages"
                  data-name="pages"
                  placeholder=""
                  type="text"
                  id="hero-pages"
                  required
                />
              </div>
              <div class="w-layout-blockcontainer container-1474 w-container">
                <label for="hero-field" class="form-label">Other</label>
                <textarea
                  placeholder="Please share anything that will help prepare for our meeting. E.g. document type, workflow etc"
                  maxlength="5000"
                  id="hero-field"
                  name="field"
                  data-name="Field"
                  class="form-input form-text-field w-input"></textarea>
              </div>
              <input
                type="submit"
                data-wait="Please wait..."
                class="footer-form-submit w-button"
                value="Submit"
              />
            </form>
            <div class="w-form-done">
              <div class="text-block-51">
                Thank you. Your submission has been received.<br /><br />Check your email for next steps.
              </div>
            </div>
            <div class="w-form-fail">
              <div>Oops! Something went wrong while submitting the form. Please email us directly at hello@formx.ai.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper full-width">
          <h2 class="product-heading">Why Logistics Companies Choose <span class="heading-gradient">FormX</span></h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card logistic-campaign-card">
              <div class="card-svg-block">
                <img src="/images/ui/logistics_landing_why-automated.svg" loading="lazy" width="128" alt="" class="card-svg tiny" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Automated Invoice Processing</h6>
                <div class="svg-card-description">Quickly extract invoice data into JSON or CSV.</div>
              </div>
            </div>
            <div class="plain-svg-card logistic-campaign-card">
              <div class="card-svg-block">
                <img src="/images/ui/logistics_landing_why-management.svg" loading="lazy" width="80" alt="" class="card-svg tiny" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Efficient Management of Bills of Lading &amp; Airway Bills</h6>
                <div class="svg-card-description">Accurately process and organize critical shipment documentation.</div>
              </div>
            </div>
            <div class="plain-svg-card logistic-campaign-card">
              <div class="card-svg-block">
                <img src="/images/ui/logistics_landing_why-integration.svg" loading="lazy" width="80" alt="" class="card-svg tiny" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Simplified Rate Sheet Integration</h6>
                <div class="svg-card-description">Instantly convert carrier rate sheets into structured data, ready for your freight management system.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">How it <span class="heading-gradient">Works</span></h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="image-content-card-wrapper">
              <div class="card-image-wrapper">
                <img src="/images/ui/logistics_landing_how-upload.svg" loading="lazy" width="202" alt="" class="grid-card-image" />
              </div>
              <div class="card-content-wrapper">
                <div class="card-content-title text-center">Upload your logistics documents<br />(PDF, Excel, scans).</div>
              </div>
            </div>
            <div class="image-content-card-wrapper">
              <div class="card-image-wrapper">
                <img src="/images/ui/logistics_landing_how-extracts.svg" loading="lazy" width="70" alt="" class="grid-card-image" />
              </div>
              <div class="card-content-wrapper">
                <div class="card-content-title text-center">Extract &amp; structure key fields automatically.</div>
              </div>
            </div>
            <div class="image-content-card-wrapper">
              <div class="card-image-wrapper">
                <img src="/images/ui/logistics_landing_how-systems.svg" loading="lazy" width="70" alt="" class="grid-card-image" />
              </div>
              <div class="card-content-wrapper">
                <div class="card-content-title text-center">Sync results to your TMS, ERP, or freight system.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script is:inline>
  (function() {
    var formEl = document.querySelector('#wf-form-Hero-Form');
    if (!formEl) return;
    formEl.addEventListener('submit', function(e) {
      e.preventDefault();
      var wform = formEl.closest('.w-form');
      var done = wform && wform.querySelector('.w-form-done');
      var fail = wform && wform.querySelector('.w-form-fail');
      var redirectUrl = formEl.getAttribute('data-redirect');
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(formEl)).toString()
      })
        .then(function() {
          formEl.style.display = 'none';
          if (done) done.style.display = 'block';
          if (redirectUrl) setTimeout(function() { window.location.href = redirectUrl; }, 1500);
        })
        .catch(function() {
          if (fail) fail.style.display = 'block';
        });
    });
  })();
</script>
