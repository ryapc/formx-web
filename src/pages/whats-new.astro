---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import WhatsNewCard from '@/components/whats-new/WhatsNewCard.astro';

const entries = await getCollection('whatsNew');
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = sorted[0];
const rest = sorted.slice(1);
---

<PageLayout
  title="What's New - FormX.ai"
  description="See what's new, what's changed, and what we're working on here at FormX.ai"
  canonicalUrl="https://www.formx.ai/whats-new/"
>
  <!-- Hero -->
  <div class="section-11 blog-hero">
    <div class="w-layout-blockcontainer container-default-8 w-container">
      <div class="whats-new-hero">
        <div class="whats-new-hero-content">
          <h1 class="whats-new-hero-h1">
            What's New with <span class="text-span-19">FormX.ai?</span>
          </h1>
          <div class="text-block-45">
            See what's new, what's changed, and what we're working on here at FormX.ai
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Featured Entry -->
  {
    featured && (
      <section class="bg-f7f8fc">
        <div class="w-layout-blockcontainer container-default-9 whats-new w-container">
          <div class="what-s-new-item featured">
            <div class="whats-new-image-wrap featured">
              <img
                loading="lazy"
                src={featured.data.featured_image}
                alt={featured.data.title}
                class="whats-new-image"
              />
            </div>
            <div class="whats-new-content-block featured">
              <div class="whats-new-tag-and-date-block">
                <div class="new-feature-tag">{featured.data.tag}</div>
                <div class="whats-new-publish-date-wrapper">
                  <div class="whats-new-publish-date">Published on {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                </div>
              </div>
              <div class="whats-new-title-description-block">
                <a href={`/whats-new/${featured.id}/`} class="whats-new-title-link">
                  {featured.data.title}
                </a>
                <div class="text-block-44 featured">{featured.data.description}</div>
              </div>
              <a href={`/whats-new/${featured.id}/`} class="link-4">Learn More &gt;</a>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- Remaining Entries -->
  {
    rest.length > 0 && (
      <section class="bg-f7f8fc">
        <div class="w-layout-blockcontainer container-default-9 whats-new w-container">
          {rest.map((entry) => (
            <div class="what-s-new-item">
              <a href={`/whats-new/${entry.id}/`} class="whats-new-image-wrap w-inline-block">
                <img
                  loading="lazy"
                  src={entry.data.featured_image}
                  alt={entry.data.title}
                  class="whats-new-image"
                />
              </a>
              <div class="whats-new-content-block">
                <div class="whats-new-tag-and-date-block">
                  <div class="new-feature-tag">{entry.data.tag}</div>
                  <div class="whats-new-publish-date-wrapper">
                    <div class="whats-new-publish-date">Published on {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                  </div>
                </div>
                <div class="whats-new-title-description-block">
                  <a href={`/whats-new/${entry.id}/`} class="whats-new-title-link">
                    {entry.data.title}
                  </a>
                  <div class="text-block-44">{entry.data.description}</div>
                </div>
                <a href={`/whats-new/${entry.id}/`} class="link-4">Learn More &gt;</a>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }
</PageLayout>
