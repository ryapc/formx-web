---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="FormX.ai - Automate Data Extraction to Empower Your Business"
  description="FormX.ai brings cutting-edge technology to your business, freeing you from manual work and minimizing human errors. Embrace a world where automation reigns, and efficiency is paramount!"
  canonicalUrl="https://www.formx.ai"
  showFooterForm={true}
>
  <Fragment slot="head">
    <!-- Preload LCP hero banner images — breakpoints match the Tailwind bg-image swap (991/992px) -->
    <link rel="preload" as="image" href="/images/ui/FormX_25Q2_hero_banner_pc@2x.webp/" fetchpriority="high" media="(min-width: 992px)" />
    <link rel="preload" as="image" href="/images/ui/FormX_25Q2_hero_banner_m@2x.webp/" fetchpriority="high" media="(max-width: 991px)" />
  </Fragment>
  <!-- Hero: LLM headline + rotating document types (Tailwind layout; filetype animation in global.css) -->
  <section
    class="hero-llm relative isolate mb-8 min-h-0 max-w-full overflow-x-clip bg-cover bg-no-repeat text-[#1cffb3] max-[991px]:bg-[position:50%_0%] max-[991px]:bg-[url(/images/ui/FormX_25Q2_hero_banner_m@2x.webp)] min-[992px]:bg-[url(/images/ui/FormX_25Q2_hero_banner_pc@2x.webp)] min-[992px]:bg-[position:0%_0%] pt-[180px] pb-[100px]"
    aria-labelledby="hero-heading"
  >
    <div class="mx-auto flex w-full max-w-[1264px] flex-col items-center px-5">
      <div class="flex w-full max-w-full flex-col items-center gap-y-4 text-center">
        <div class="flex w-full flex-col items-center gap-y-0 text-center">
          <h1
            id="hero-heading"
            class="mb-0 w-full text-balance font-bold leading-snug tracking-tight text-white text-[2rem] max-[991px]:px-5 md:max-[991px]:px-20 md:text-[2.75rem] lg:px-0 lg:text-5xl lg:leading-snug"
          >
            Automate Document Workflow with
          </h1>
          <div class="hero-llm__filetype-line" aria-label="Rotating examples of document types you can read with FormX">
            <div class="hero-llm__filetype-track">
              <div class="hero-llm__filetype-slot">
                <span class="text-[2rem] font-bold leading-snug text-white/90 md:text-[2.75rem] lg:text-5xl lg:leading-snug"><span class="text-white">​<span class="text-[#1cffb3]">AI</span> and Read </span>PDF Files</span>
              </div>
              <div class="hero-llm__filetype-slot">
                <span class="text-[2rem] font-bold leading-snug text-white/90 md:text-[2.75rem] lg:text-5xl lg:leading-snug"><span class="text-white"><span class="text-[#1cffb3]">AI</span> and Read </span>Invoices</span>
              </div>
              <div class="hero-llm__filetype-slot">
                <span class="text-[2rem] font-bold leading-snug text-white/90 md:text-[2.75rem] lg:text-5xl lg:leading-snug"><span class="text-white"><span class="text-[#1cffb3]">AI</span> and Read </span>Receipts</span>
              </div>
              <div class="hero-llm__filetype-slot">
                <span class="text-[2rem] font-bold leading-snug text-white/90 md:text-[2.75rem] lg:text-5xl lg:leading-snug"><span class="text-white"><span class="text-[#1cffb3]">AI</span> and Read </span>Sheets</span>
              </div>
              <div class="hero-llm__filetype-slot">
                <span class="text-[2rem] font-bold leading-snug text-white/90 md:text-[2.75rem] lg:text-5xl lg:leading-snug"><span class="text-white"><span class="text-[#1cffb3]">AI</span> and Read </span>ID Cards</span>
              </div>
            </div>
          </div>
        </div>
        <p
          class="max-w-full text-center text-base font-normal leading-6 text-white max-[991px]:px-5 md:max-[991px]:px-20 lg:px-0"
        >
          Achieve more with AI-powered workflows designed to simplify and accelerate your business processes.
        </p>
      </div>
      <div class="mt-8 flex w-full max-w-full flex-col items-stretch justify-center gap-4 max-[991px]:px-5 md:max-[991px]:px-20 sm:flex-row sm:items-center sm:justify-center lg:mt-10 lg:px-0">
        <a
          href="https://formextractorai.com/signup"
          target="_blank"
          class="button-primary mbp-full-width margin-right-16px new-green-secondary w-button sm:mb-0 sm:mr-4">Try it yourself</a>
        <a
          href="/schedule-demo/"
          target="_blank"
          class="button-primary mbp-full-width margin-right-16px new-green w-button">Schedule Demo &nbsp;-&gt;</a>
      </div>
    </div>
  </section>

  <!-- Logo carousel -->
  <div class="hero__llm__logowrap freeze">
    <ul role="list" class="logo-carousel freeze">
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="MTR"><img width="150" height="60" loading="lazy" alt="MTR" src="/images/pages/homepage_logo-gray-MTR@2x.png" class="logo-image"/></a></li>
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="Google"><img width="150" height="60" loading="lazy" alt="Google" src="/images/pages/homepage_logo-gray-Google@2x.png" class="logo-image"/></a></li>
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="Wilson Group"><img width="150" height="60" loading="lazy" alt="Wilson Group" src="/images/pages/homepage_logo-gray-WilsonGroup@2x.png" class="logo-image"/></a></li>
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="LINK"><img width="150" height="60" loading="lazy" alt="LINK" src="/images/pages/homepage_logo-gray-LINK@2x.png" class="logo-image"/></a></li>
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="Lika Hsin"><img width="150" height="60" loading="lazy" alt="Lika Hsin" src="/images/pages/homepage_logo-gray-LIKAHSIN@2x.png" class="logo-image"/></a></li>
      <li class="logo-carousel-item"><a href="/index#" class="logo-link w-inline-block" aria-label="Ayala Malls"><img width="150" height="60" loading="lazy" alt="Ayala Malls" src="/images/pages/homepage_logo-gray-AyalaMalls@2x.png" class="logo-image"/></a></li>
    </ul>
  </div>

  <!-- Automate Data Extraction steps -->
  <div id="Learn-more" class="section">
    <div class="w-layout-blockcontainer container-default w-container">
      <div class="home-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">Automate Data Extraction in Minutes<br/>The Easiest Way to <span class="heading-gradient-v3">Extract Data</span> from Any Document<br/></h2>
          <div class="product-subheading">Follow these 3 simple steps and unlock streamlined information extraction &amp;&#x2028;seamless integration with your existing workflows.</div>
        </div>
        <div class="home-automate-section-content-wrap">
          <div>
            <img src="/images/pages/automate_data_extraction@2x.webp" loading="lazy" width="2560" height="828" alt="" srcset="/images/pages/automate_data_extraction@2x-p-500.webp 500w, /images/pages/automate_data_extraction@2x-p-800.webp 800w, /images/pages/automate_data_extraction@2x-p-1080.webp 1080w, /images/pages/automate_data_extraction@2x-p-1600.webp 1600w, /images/pages/automate_data_extraction@2x-p-2000.webp 2000w, /images/pages/automate_data_extraction@2x.webp 2560w" sizes="(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px" class="image-78"/>
          </div>
          <div class="_3-block-grid">
            <div class="plain-svg-card card-content-center bg-transparent px-12-5 py-0">
              <div class="card-svg-block svg-center flex-center"><div class="steps-number">1</div></div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Create an Extractor</div>
                <div class="svg-card-description">Choose from our pre-built extractors or design your own to fit your specific document needs.</div>
              </div>
            </div>
            <div class="plain-svg-card card-content-center bg-transparent px-12-5 py-0">
              <div class="card-svg-block svg-center flex-center"><div class="steps-number">2</div></div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Prepare Your Samples</div>
                <div class="svg-card-description">Upload sample documents and &nbsp;define the data fields you want to extract.</div>
              </div>
            </div>
            <div class="plain-svg-card card-content-center bg-transparent px-12-5 py-0">
              <div class="card-svg-block svg-center flex-center"><div class="steps-number">3</div></div>
              <div class="svg-card-content-wrapper">
                <div class="svg-card-title bold-text">Connect the API</div>
                <div class="svg-card-description">Integrate FormX.ai's API into your system to seamlessly import structured JSON files.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Document types -->
