        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb57-13f6ea65" href="/solutions/address-proof/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-miltiple.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Member Applications</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb5c-13f6ea65" href="/solutions/bookkeeping/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-reports.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Annual Reports</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb61-13f6ea65" href="/solutions/business-certificates/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-certificate.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Certificate</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb66-13f6ea65" href="/solutions/id-card-ocr/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-license.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Licenses</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb6b-13f6ea65" href="/solutions/zapier-and-n8n/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-more.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">And much more</div></div></a>
      </div>
    </div>
  </div>

  <!-- Improve accuracy section -->
  <div class="section">
    <div class="w-layout-blockcontainer container-default w-container">
      <div class="home-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">Improve Accuracy Continuously with <span class="heading-gradient-v3 mobile-break">Production Data</span></h2>
          <div class="product-subheading">Your extraction model's accuracy improves over time with real-world feedback.</div>
        </div>
        <img src="/images/pages/improvement-with-production_data@2x.webp" loading="lazy" width="2563" height="680" sizes="(max-width: 767px) 100vw, (max-width: 991px) 95vw, 940px" alt="" srcset="/images/pages/improvement-with-production_data@2x-p-500.webp 500w, /images/pages/improvement-with-production_data@2x-p-800.webp 800w, /images/pages/improvement-with-production_data@2x-p-1080.webp 1080w, /images/pages/improvement-with-production_data@2x-p-1600.webp 1600w, /images/pages/improvement-with-production_data@2x-p-2000.webp 2000w, /images/pages/improvement-with-production_data@2x.webp 2563w" class="desktop-img"/>
        <img src="/images/pages/improvement-with-production_data_m@2x.webp" loading="lazy" width="670" height="1800" sizes="(max-width: 479px) 100vw, 335px" alt="" srcset="/images/pages/improvement-with-production_data_m@2x-p-500.webp 500w, /images/pages/improvement-with-production_data_m@2x.webp 670w" class="image-73"/>
      </div>
    </div>
  </div>

  <!-- Document extraction pipeline mobile image -->
  <div class="home-heading-content-wrapper">
    <img src="/images/pages/document_extraction_pipeline_m@2x.webp" loading="lazy" width="750" height="4496" sizes="100vw" alt="" srcset="/images/pages/document_extraction_pipeline_m@2x-p-500.webp 500w, /images/pages/document_extraction_pipeline_m@2x.webp 750w" class="mobile-img"/>
  </div>

