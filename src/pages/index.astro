      </div>
    </div>
    <img src="/images/pages/document_extraction_pipeline@2x.webp" loading="lazy" width="3840" height="2088" sizes="(max-width: 1919px) 100vw, 1920px" alt="" srcset="/images/pages/document_extraction_pipeline@2x-p-500.webp 500w, /images/pages/document_extraction_pipeline@2x-p-800.webp 800w, /images/pages/document_extraction_pipeline@2x-p-1080.webp 1080w, /images/pages/document_extraction_pipeline@2x-p-1600.webp 1600w, /images/pages/document_extraction_pipeline@2x-p-2000.webp 2000w, /images/pages/document_extraction_pipeline@2x-p-2600.webp 2600w, /images/pages/document_extraction_pipeline@2x-p-3200.webp 3200w, /images/pages/document_extraction_pipeline@2x.webp 3840w" class="desktop-img"/>
  </div>

  <!-- More Powerful Than Just LLM -->
  <div class="section">
    <div class="w-layout-blockcontainer container-default w-container">
      <div class="home-heading-content-wrapper">
        <div class="product-heading-wrapper mw-800px">
          <h2 class="product-heading">More Powerful Than <span class="heading-gradient-v3">Just LLM</span></h2>
          <div class="product-subheading">Leverage LLM technology and seamlessly integrate it into your workflow.</div>
        </div>
