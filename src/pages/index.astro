        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb3e-13f6ea65" href="/solutions/receipts/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-receipt.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Receipts</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb43-13f6ea65" href="/solutions/finance/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-bank-statement.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Bank Statements</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb48-13f6ea65" href="/solutions/retail/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-contracts.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Contracts</div></div></a>
        <a id="w-node-_9743c4bc-39b5-1b70-7e2a-3b3e7e2fcb4d-13f6ea65" href="/solutions/human-resources/" class="home-document-type-card---phone w-inline-block"><div class="home-document-type-content-wrap"><img src="/images/pages/home_document-types-applications.svg" loading="lazy" width="70" height="70" alt=""/><div class="doc-type-font">Applications</div></div></a>
